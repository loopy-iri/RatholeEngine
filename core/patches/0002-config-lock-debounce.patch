+const CONFIG_READ_RETRIES: usize = 3;
+const CONFIG_READ_RETRY_DELAY: Duration = Duration::from_millis(50);
+
+fn config_lock_path(path: &Path) -> PathBuf {
+    let mut lock_path = path.as_os_str().to_os_string();
+    lock_path.push(".lock");
+    PathBuf::from(lock_path)
+}
+
+async fn try_read_config(path: &Path) -> Result<Config> {
+    let mut last_error = None;
+
+    for attempt in 0..CONFIG_READ_RETRIES {
+        let path = path.to_owned();
+        let result = tokio::task::spawn_blocking(move || -> Result<Config> {
+            let lock = OpenOptions::new()
+                .create(true)
+                .read(true)
+                .write(true)
+                .open(config_lock_path(&path))
+                .with_context(|| "Failed to open the configuration lock")?;
+            FileExt::lock_shared(&lock)
+                .with_context(|| "Failed to acquire the shared configuration lock")?;
+            let raw = std::fs::read_to_string(&path)
+                .with_context(|| format!("Failed to read the config {:?}", path))?;
+            let config = Config::from_str(&raw).with_context(|| {
+                "Configuration is invalid. Please refer to the configuration specification."
+            });
+            let _ = FileExt::unlock(&lock);
+            config
+        })
+        .await
+        .map_err(|error| anyhow!("Configuration reader task failed: {error}"))?;
+
+        match result {
+            Ok(config) => return Ok(config),
+            Err(error) => last_error = Some(error),
+        }
+        if attempt + 1 < CONFIG_READ_RETRIES {
+            tokio::time::sleep(CONFIG_READ_RETRY_DELAY).await;
+        }
+    }
+
+    Err(last_error.unwrap_or_else(|| anyhow!("Configuration read failed without an attempt")))
+}
