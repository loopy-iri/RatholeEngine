+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::config::{TransportType, WebsocketConfig};
+
+    #[tokio::test]
+    async fn handshake_failure_returns_error_without_panicking() {
+        let listener = TcpListener::bind("127.0.0.1:0").await.unwrap();
+        let listen_addr = listener.local_addr().unwrap();
+        tokio::spawn(async move {
+            let (stream, _) = listener.accept().await.unwrap();
+            drop(stream);
+        });
+
+        let config = TransportConfig {
+            transport_type: TransportType::Websocket,
+            websocket: Some(WebsocketConfig {
+                tls: false,
+                path: "/".to_string(),
+            }),
+            ..Default::default()
+        };
+        let transport = WebsocketTransport::new(&config).unwrap();
+        let remote = AddrMaybeCached::new(&listen_addr.to_string());
+        let task = tokio::spawn(async move { transport.connect(&remote).await });
+        let result = task.await.expect("websocket connect panicked");
+        assert!(result.is_err());
+    }
+}
