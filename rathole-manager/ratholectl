#!/usr/bin/env bash
# ratholectl — mdirit nvdhai tunnel rathole + tvlid khodkar server.toml va config nginx
# rooye server Iran ejra mishavad.
# nokte: amdan az `set -e` estefade nmiknim chvn algvi `jq | while read` ba pipefail kd
# khorooji ghirsfr midahad va ba -e askript ra vst tvlid config mibndd. khtaha sarih ba die mdirit mishavand.
set -uo pipefail

# common.sh agar knar file bashd, tavabe eshteraki ra lvd kon
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd || echo "$PWD")"
[ -f "$SCRIPT_DIR/common.sh" ] && source "$SCRIPT_DIR/common.sh"

# pak-sazi temp files dar khorooj (chh movafagh chh khata)
# har masir dar yek onsor arraye zkhirh mishavad ta msirhai darai faasele ham dorost pak shavand.
_RTH_TMP=()
_rth_cleanup(){ [ "${#_RTH_TMP[@]}" -gt 0 ] && rm -rf -- "${_RTH_TMP[@]}"; }
trap _rth_cleanup EXIT INT TERM

rth_mktemp(){ local p; p="$(mktemp "$@")" || return 1; _RTH_TMP+=("$p"); echo "$p"; }
rth_mktempd(){ local d; d="$(mktemp -d "$@")" || return 1; _RTH_TMP+=("$d"); echo "$d"; }


STATE="/etc/rathole-manager/state.json"
SERVER_TOML="/etc/rathole/server.toml"
NOISE_TOML="/etc/rathole/noise-server.toml"
NGINX_CONF="/etc/nginx/conf.d/rathole.conf"
STREAM_CONF="/etc/nginx/stream.d/rathole-stream.conf"
RATHOLE_SVC="rathole-server"
NOISE_SVC="rathole-noise"
NOISE_PATTERN_DEFAULT="Noise_NK_25519_ChaChaPoly_BLAKE2s"

c_g(){ printf '\033[1;32m%s\033[0m' "$*"; }
c_r(){ printf '\033[1;31m%s\033[0m' "$*"; }
c_y(){ printf '\033[1;33m%s\033[0m' "$*"; }
log(){ printf '%s %s\n' "$(c_g '[+]')" "$*"; }
warn(){ printf '%s %s\n' "$(c_y '[*]')" "$*"; }
err(){ printf '%s %s\n' "$(c_r '[!]')" "$*" >&2; }
die(){ err "$*"; exit 1; }
ask_yn(){ local p="$1" a; read -rp "$p [y/N]: " a; [[ "$a" =~ ^[Yy]$ ]]; }

need_root(){ [ "$(id -u)" -eq 0 ] || die "bayad ba root ejra shavad (sudo)."; }
need_bin(){ command -v "$1" >/dev/null 2>&1 || die "niaz be '$1' ast; aval install-panel.sh ra ejra kon."; }

ensure_state(){
  [ -f "$STATE" ] || die "hnvz init nashode. aval ejra kon: ratholectl init"
}

gen_token(){ openssl rand -hex 16; }

# ---------- tvlid keypair-e noise (X25519) baraye transport-e ramznegari-shode ----------
# rathole --genkey do khat mide: "Private Key:" va "Public Key:" (base64). faghat agar hanooz set nashode.
# NOTE: format-e daghigh-e khoruji-ye 'rathole --genkey' bayad ba binary-ye vaghei tayid shavad;
#       parse be sorat-e defensive: aval do khat-e base64-e pas az barchasb, dar ghir-e-in-surat har do khat-e base64.
noise_genkey(){
  local have_priv have_pub
  have_priv="$(jq -r '.noise_privkey // empty' "$STATE" 2>/dev/null)"
  have_pub="$(jq -r '.noise_pubkey // empty' "$STATE" 2>/dev/null)"
  [ -n "$have_priv" ] && [ -n "$have_pub" ] && return 0   # az ghabl vojood darad
  command -v rathole >/dev/null 2>&1 || die "binary-e 'rathole' peyda nashod; nemitavan keypair-e noise sakht."
  local out priv pub
  out="$(rathole --genkey 2>/dev/null)" || die "'rathole --genkey' shekast khord."
  # tarjih: khatt-e baʔd az 'Private Key'/'Public Key'; fallback: avval/dovom khatt-e base64-mannad.
  priv="$(echo "$out" | grep -iA1 'private' | grep -vi 'private' | tr -d '[:space:]' | head -n1)"
  pub="$(echo "$out"  | grep -iA1 'public'  | grep -vi 'public'  | tr -d '[:space:]' | head -n1)"
  if [ -z "$priv" ] || [ -z "$pub" ]; then
    # fallback: hame khatt-haye base64-mannad ra bardar (avval=priv, dovom=pub)
    local lines; lines="$(echo "$out" | grep -oE '[A-Za-z0-9+/]{40,}={0,2}')"
    priv="$(echo "$lines" | sed -n '1p')"; pub="$(echo "$lines" | sed -n '2p')"
  fi
  [ -n "$priv" ] && [ -n "$pub" ] || die "natvanestam keypair-e noise ra az khoruji-ye rathole --genkey parse konam."
  state_set '.noise_privkey' "$priv"
  state_set '.noise_pubkey'  "$pub"
  log "keypair-e noise tvlid shod (kelid-e omomi montasher mishavad, khsvsi rooye Iran mimanad)."
}

# ---------- grftn gvahi Let's Encrypt (standalone) ----------
obtain_cert(){ # $1=domain ; khorooji: masir gvahi dar /etc/letsencrypt
  local domain="$1" email
  command -v certbot >/dev/null 2>&1 || { err "certbot nasb nist."; return 1; }
  read -rp "aimil baraye Let's Encrypt: " email
  [ -n "$email" ] || { err "aimil lazem ast."; return 1; }
  warn "baraye grftn gvahi, nginx mvghtaan motevaghef mishavad (niaz be port 80 azad va DNS dorost $domain)."
  local was_active=0
  systemctl is-active --quiet nginx && { was_active=1; systemctl stop nginx; }
  if certbot certonly --standalone --non-interactive --agree-tos \
       -m "$email" -d "$domain"; then
    log "gvahi grfth shod: /etc/letsencrypt/live/$domain/"
    [ "$was_active" -eq 1 ] && systemctl start nginx || true
    return 0
  else
    err "grftn gvahi shekast khord (DNS? port 80 bsth? filtr?)."
    [ "$was_active" -eq 1 ] && systemctl start nginx || true
    return 1
  fi
}

# ---------- khvandn tanzimat az state ----------
s_get(){ jq -r "$1" "$STATE"; }

# ---------- backup va restore ----------
cmd_backup(){
  need_root; ensure_state
  local out="${1:-/root/rathole-panel-backup-$(date +%Y%m%d-%H%M%S).tar.gz}"
  tar -czf "$out" -C / "${STATE#/}" 2>/dev/null || die "sakht backup shekast khord."
  log "backup sakhte shod: $out"
  echo "shaml state.json (damnh, pvrtha, nvdha, tvknha, SNI). az rooye an hmhchiz baztolid mishavad."
  warn "gvahiha va filehaye nginx dar in backup nistnd (jda mdirit mishavand)."
}

cmd_restore(){
  need_root; need_bin jq
  local f="${1:-}"
  [ -n "$f" ] && [ -f "$f" ] || die "file backup peyda nashod: $f"
  local tmp; tmp="$(rth_mktempd)"
  tar -xzf "$f" -C "$tmp" 2>/dev/null || die "baz kardan backup shekast khord (frmt?)."
  local st; st="$(find "$tmp" -name state.json -print -quit 2>/dev/null)"
  [ -n "$st" ] || die "state.json dar backup nist."
  jq -e . "$st" >/dev/null 2>&1 || die "state.json namotabar ast."
  mkdir -p "$(dirname "$STATE")"
  cp -f "$st" "$STATE"
  rm -rf "$tmp"
  log "state restore shod az: $f (damnh: $(s_get '.domain') , nodeha: $(jq '.nodes|length' "$STATE"))"
  regenerate
  systemctl enable --now "$RATHOLE_SVC" 2>/dev/null || true
  log "restore kamel shod. nodeha ba haman tokenha bedoon taghir dvbarh vsl mishavand."
  warn "motmaen shv gvahiha dar masir dakhl state mvjvdnd (dar ghir ainsvrt dvbarh begir)."
}

# ---------- dstvr init ----------
cmd_init(){
  need_root; need_bin jq
  local domain="" cert_fc="" cert_key="" ctrl="" fake="" sub="" dstart="" astart="" nconf="" interactive=1 use_certbot=0 restore_file=""
  # halat flgmhvr (non-interactive) — agar har flgi dade shvd, taamoli nist
  while [ $# -gt 0 ]; do
    case "$1" in
      --domain)        domain="$2"; interactive=0; shift 2;;
      --fullchain)     cert_fc="$2"; shift 2;;
      --key)           cert_key="$2"; shift 2;;
      --control-port)  ctrl="$2"; shift 2;;
      --fake-port)     fake="$2"; shift 2;;
      --sub-port)      sub="$2"; shift 2;;
      --data-start)    dstart="$2"; shift 2;;
      --api-start)     astart="$2"; shift 2;;
      --nginx-conf)    nconf="$2"; shift 2;;
      --restore)       restore_file="$2"; shift 2;;
      --certbot)       use_certbot=1; shift;;
      *) shift;;
    esac
  done

  # halat restore: agar file backup dade shode ya (taamoli) karbar masir dad
  if [ "$interactive" -eq 1 ] && [ -z "$restore_file" ]; then
    read -rp "adres file backup baraye restore (khali = nasb tazh): " restore_file
  fi
  if [ -n "$restore_file" ]; then
    cmd_restore "$restore_file"
    return
  fi

  if [ "$interactive" -eq 1 ]; then
    read -rp "damnh (masalan btli.ir): " domain
    [ -n "$domain" ] || die "damnh alzami ast."
    read -rp "masir fullchain.pem [/root/cert/${domain}/fullchain.pem]: " cert_fc
    read -rp "masir privkey.pem [/root/cert/${domain}/privkey.pem]: " cert_key
    read -rp "file config nginx baraye tvlid/riplis [/etc/nginx/conf.d/rathole.conf]: " nconf
    read -rp "port kontroli lvkal rathole [2333]: " ctrl
    read -rp "port sait fik/panel (default) [8080]: " fake
    read -rp "port sabaskripshn [2096]: " sub
    read -rp "shrva shmarh port dita [1001]: " dstart
    read -rp "shrva shmarh port mdirit(api) [7001]: " astart
  fi

  # pishfrzha
  [ -n "$domain" ] || die "damnh lazem ast (--domain ...)."
  cert_fc="${cert_fc:-/root/cert/${domain}/fullchain.pem}"
  cert_key="${cert_key:-/root/cert/${domain}/privkey.pem}"
  nconf="${nconf:-$NGINX_CONF}"
  ctrl="${ctrl:-2333}"; fake="${fake:-8080}"; sub="${sub:-2096}"
  dstart="${dstart:-1001}"; astart="${astart:-7001}"

  # gvahi: chvn maamoolan az ghabl dari, certbot fght dar soorat drkhvast sarih ya entekhab dar halat taamoli
  if [ ! -f "$cert_fc" ] || [ ! -f "$cert_key" ]; then
    warn "gvahi dar masir dadhshdh peyda nashod: $cert_fc"
    if [ "$use_certbot" -eq 1 ] || { [ "$interactive" -eq 1 ] && ask_yn "ba certbot grfth shvd?"; }; then
      if obtain_cert "$domain"; then
        cert_fc="/etc/letsencrypt/live/${domain}/fullchain.pem"
        cert_key="/etc/letsencrypt/live/${domain}/privkey.pem"
      else
        warn "bedoon gvahi adamh midhim; ta ghabl az vojood gvahi nginx bala nmiaid."
      fi
    else
      warn "az gvahi mojood estefade mishvd; motmaen shv masir dorost ast."
    fi
  else
    log "gvahi mojood estefade mishavad: $cert_fc"
  fi

  mkdir -p "$(dirname "$STATE")"
  jq -n \
    --arg d "$domain" --arg fc "$cert_fc" --arg key "$cert_key" --arg nc "$nconf" \
    --argjson ctrl "$ctrl" --argjson fake "$fake" --argjson sub "$sub" \
    --argjson ds "$dstart" --argjson apst "$astart" \
    '{domain:$d, cert_fullchain:$fc, cert_key:$key, nginx_conf:$nc, control_port:$ctrl,
      fake_port:$fake, sub_port:$sub, data_port_start:$ds, api_port_start:$apst, nodes:[]}' \
    > "$STATE"
  log "state sakhte shod: $STATE (nginx → $nconf)"
  regenerate
  log "init kamel shod."
}

# ---------- tkhsis port azad ----------
next_port(){ # $1=field (port|api_local_port) $2=start
  local field="$1" start="$2" used p
  # HAME-ye port-haye rezerv ra dar nazar begir (na faghat yek field) ta do bind_addr-e
  # yeksan (mesl data-port == api-port ya == control/fake/sub/...) sakhte nashavad.
  used="$(jq -r '
    ([.nodes[].port // empty]
     + [.nodes[].api_local_port // empty]
     + [.control_port, .fake_port, .sub_port, .internal_port, .plain_port, .hub_port, .noise_port]
    ) | map(select(. != null)) | @tsv' "$STATE")"
  p="$start"
  while echo "$used" | tr '\t' '\n' | grep -qx "$p"; do p=$((p+1)); done
  echo "$p"
}

# ---------- dstvr add ----------
# nam-haye rezerv-shode ke ba entry-haye sabet-e map-e nginx tadakhol darand
# (masalan 'sub' ke '~^/sub/' ra shadow mikonad). in-ha nabayad name-e node bashand.
is_reserved_name(){ case "$1" in sub|default) return 0 ;; *) return 1 ;; esac; }

cmd_add(){
  need_root; need_bin jq; ensure_state
  local name="${1:-}" inbound="${2:-}" api_port="${3:-}"
  [ -n "$name" ] && [ -n "$inbound" ] || die "estefade: ratholectl add <name> <inbound_port> [--api-port <port>]"
  echo "$name" | grep -qE '^[a-zA-Z0-9_-]+$' || die "name fght hrvf/adad/khttirh mjaz ast."
  is_reserved_name "$name" && die "name '$name' rezerv shode (ba masir-e sabet-e nginx tadakhol darad); name-e digari entekhab kon."
  echo "$inbound" | grep -qE '^[0-9]+$' || die "inbound bayad adad bashad."
  [ -n "$api_port" ] && { echo "$api_port" | grep -qE '^[0-9]+$' || die "port api bayad adad bashad."; }
  if jq -e --arg n "$name" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null; then
    die "node '$name' az ghabl vojood darad."
  fi

  local dstart astart dport aport token atoken
  dstart="$(s_get '.data_port_start')"
  astart="$(s_get '.api_port_start')"
  dport="$(next_port port "$dstart")"
  token="$(gen_token)"

  local node_json
  node_json="$(jq -n --arg n "$name" --argjson p "$dport" \
                     --argjson ib "$inbound" --arg t "$token" \
                     '{name:$n, port:$p, inbound_port:$ib, token:$t}')"

  # port mdirit ekhtiari
  if [ -n "$api_port" ]; then
    aport="$(next_port api_local_port "$astart")"
    atoken="$(gen_token)"
    node_json="$(echo "$node_json" | jq --argjson ap "$aport" --argjson aib "$api_port" --arg at "$atoken" \
                  '. + {api_local_port:$ap, api_inbound_port:$aib, api_token:$at}')"
  fi

  # faghat agar neveshtan-e state movafagh bood, success log/regenerate anjam shavad.
  jq --argjson node "$node_json" '.nodes += [$node]' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE" \
    || { rm -f "$STATE.tmp"; die "sabt-e node dar state shekast khord."; }
  log "node '$name' ezafe shod (path=/$name → 127.0.0.1:$dport)."
  regenerate
  print_node_install "$name"
}

# ---------- dstvr rm ----------
cmd_rm(){
  need_root; need_bin jq; ensure_state
  local name="${1:-}"
  [ -n "$name" ] || die "estefade: ratholectl rm <name>"
  jq -e --arg n "$name" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null || die "node '$name' peyda nashod."
  jq --arg n "$name" '.nodes |= map(select(.name!=$n))' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
  log "node '$name' hazf shod."
  regenerate
}

# ---------- dstvr ls ----------
cmd_ls(){
  need_bin jq; ensure_state
  local domain; domain="$(s_get '.domain')"
  printf '%-14s %-8s %-12s %-10s %s\n' "NAME" "PORT" "INBOUND" "API" "USER PATH"
  printf '%s\n' "--------------------------------------------------------------"
  jq -r '.nodes[] | [.name, (.port|tostring), (.inbound_port|tostring),
          ((.api_local_port // "-")|tostring)] | @tsv' "$STATE" |
  while IFS=$'\t' read -r n p ib ap; do
    printf '%-14s %-8s %-12s %-10s %s\n' "$n" "$p" "$ib" "$ap" "https://$domain/$n"
  done
}

# ---------- tvlid server.toml ----------
gen_server_toml(){
  local ctrl; ctrl="$(s_get '.control_port')"
  case "$ctrl" in ''|null) ctrl=2333 ;; esac
  {
    echo "# tvlid khodkar tvst ratholectl — dasti virayesh nakon"
    echo "[server]"
    echo "bind_addr = \"127.0.0.1:${ctrl}\""
    echo "heartbeat_interval = 30"
    echo
    echo "[server.transport]"
    echo "type = \"websocket\""
    echo "[server.transport.websocket]"
    echo "tls = false"
    echo
    jq -r '.nodes[] | @base64' "$STATE" | while read -r row; do
      _j(){ echo "$row" | base64 -d | jq -r "$1"; }
      local name port token aport atoken
      name="$(_j '.name')"; port="$(_j '.port')"; token="$(_j '.token')"
      # node-haye noise service-eshan tooye noise-server.toml mirvad (na inja) — vagarna do prose yek bind_addr ra bind mikonand.
      [ "$(_j '.transport // empty')" = noise ] && continue
      echo "[server.services.${name}]"
      echo "token = \"${token}\""
      echo "bind_addr = \"127.0.0.1:${port}\""
      echo "type = \"tcp\""
      echo
      aport="$(_j '.api_local_port // empty')"
      if [ -n "$aport" ]; then
        atoken="$(_j '.api_token')"
        echo "[server.services.${name}_api]"
        echo "token = \"${atoken}\""
        echo "bind_addr = \"127.0.0.1:${aport}\""
        echo "type = \"tcp\""
        echo
      fi
    done
  } > "$SERVER_TOML.tmp"
  # neveshtan in-place (hefz inode) ta rathole ba config_watcher khodesh hot-reload konad
  cat "$SERVER_TOML.tmp" > "$SERVER_TOML" && rm -f "$SERVER_TOML.tmp"
}

# ---------- tvlid noise-server.toml (instans-e dovom-e rathole ba transport-e noise, rooye port-e omomi) ----------
# faghat node-hayi ke transport=noise darand inja miayand. bind_addr-e server omomi ast (nginx dar in masir nist).
gen_noise_server_toml(){
  local nport pat priv
  nport="$(jq -r '.noise_port // empty' "$STATE" 2>/dev/null)"
  [ -n "$nport" ] && [ "$nport" != null ] || return 0   # noise khamoosh: toml nemisazim
  pat="$(jq -r '.noise_pattern // empty' "$STATE" 2>/dev/null)"; [ -n "$pat" ] && [ "$pat" != null ] || pat="$NOISE_PATTERN_DEFAULT"
  priv="$(jq -r '.noise_privkey // empty' "$STATE" 2>/dev/null)"
  {
    echo "# tvlid khodkar tvst ratholectl — dasti virayesh nakon (transport=noise)"
    echo "[server]"
    echo "bind_addr = \"0.0.0.0:${nport}\""
    echo "heartbeat_interval = 30"
    echo
    echo "[server.transport]"
    echo "type = \"noise\""
    echo "[server.transport.noise]"
    echo "pattern = \"${pat}\""
    echo "local_private_key = \"${priv}\""
    echo
    jq -r '.nodes[] | @base64' "$STATE" | while read -r row; do
      _j(){ echo "$row" | base64 -d | jq -r "$1"; }
      local name port token aport atoken
      [ "$(_j '.transport // empty')" = noise ] || continue   # faghat node-haye noise
      name="$(_j '.name')"; port="$(_j '.port')"; token="$(_j '.token')"
      echo "[server.services.${name}]"
      echo "token = \"${token}\""
      echo "bind_addr = \"127.0.0.1:${port}\""
      echo "type = \"tcp\""
      echo
      aport="$(_j '.api_local_port // empty')"
      if [ -n "$aport" ]; then
        atoken="$(_j '.api_token')"
        echo "[server.services.${name}_api]"
        echo "token = \"${atoken}\""
        echo "bind_addr = \"127.0.0.1:${aport}\""
        echo "type = \"tcp\""
        echo
      fi
    done
  } > "$NOISE_TOML.tmp"
  # neveshtan in-place (hefz inode) baraye hot-reload-e rathole-noise
  cat "$NOISE_TOML.tmp" > "$NOISE_TOML" && rm -f "$NOISE_TOML.tmp"
}

# ---------- tvlid config nginx ----------
gen_nginx_conf(){
  local domain cert_fc cert_key ctrl fake sub
  domain="$(s_get '.domain')";       cert_fc="$(s_get '.cert_fullchain')"
  cert_key="$(s_get '.cert_key')";   ctrl="$(s_get '.control_port')"
  fake="$(s_get '.fake_port')";      sub="$(s_get '.sub_port')"
  # mghavmsazi: agar mghdari khali/null bvd, pishfarz amn bgzar ta map motabar bmand
  case "$ctrl" in ''|null) ctrl=2333 ;; esac
  case "$fake" in ''|null) fake=8080 ;; esac
  case "$sub"  in ''|null) sub=2096 ;; esac
  [ -n "$domain" ] && [ "$domain" != null ] || die "state naghes ast (domain khali). dvbarh init bezan."
  local internal sni_count listen_line
  internal="$(jq -r '.internal_port // 8443' "$STATE" 2>/dev/null)"; case "$internal" in ''|null) internal=8443 ;; esac
  sni_count="$(jq '[.nodes[]|select(.sni!=null)]|length' "$STATE" 2>/dev/null)"; [ -n "$sni_count" ] || sni_count=0
  if [ "$sni_count" -gt 0 ]; then listen_line="listen 127.0.0.1:${internal} ssl http2;"; else listen_line="listen 443 ssl http2;"; fi
  # damnhhaye ezafi bedoon http2 (jelogiri az hoshdar duplicate listen option)
  local listen_line_extra="${listen_line/ http2/}"
  # damnh asli default_server ta Host-haye sabt-nashode (masalan CNAME Cloudflare) ham panel/site ra bebinand.
  # faghat vaghti default_server bardar ke hich vhost digari (masalan pasteshare) an ra naghatereft — jelogiri az "duplicate default server".
  local listen_line_primary="$listen_line"
  if [ "$sni_count" -eq 0 ]; then
    local ext_default=0
    if grep -rlsE 'listen[^;]*\bdefault_server\b' /etc/nginx/sites-enabled /etc/nginx/conf.d 2>/dev/null \
         | grep -vxF "$NGINX_CONF" | grep -q .; then ext_default=1; fi
    [ "$ext_default" -eq 0 ] && listen_line_primary="listen 443 ssl http2 default_server;"
  fi

  # location ekhtiari baraye panel web (paidar dar brabr regen)
  local hub_port hub_block=""
  hub_port="$(jq -r '.hub_port // empty' "$STATE" 2>/dev/null)"
  if [ -n "$hub_port" ] && [ "$hub_port" != null ]; then
    hub_block="$(cat <<HB

    location /hub/ {
        proxy_pass http://127.0.0.1:${hub_port}/;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection \$connection_upgrade;
        proxy_read_timeout 3600s;
    }
HB
)"
  fi
  {
    echo "# tvlid khodkar tvst ratholectl — dasti virayesh nakon"
    echo "# masir(path) dita -> port lvkal rathole"
    echo "map \$uri \$backend_port {"
    echo "    default      ${fake};"
    echo "    ~^/sub/      ${sub};"
    jq -r '.nodes[] | select(.sni == null) | [.name,(.port|tostring)] | @tsv' "$STATE" |
    while IFS=$'\t' read -r n p; do
      printf '    "~^/%s($|/)"   %s;\n' "$n" "$p"
    done
    echo "}"
    echo
    echo "# rishh: sait fik (bedoon upgrade) ya channel kontroli rathole (ba websocket)"
    echo "map \$http_upgrade \$root_backend {"
    echo "    default      ${fake};"
    echo "    websocket    ${ctrl};"
    echo "}"
    echo
    cat <<NGINX
server {
    ${listen_line_primary}
    server_name ${domain};

    ssl_certificate     ${cert_fc};
    ssl_certificate_key ${cert_key};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
