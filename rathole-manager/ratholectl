# ---------- kcp/FEC tunnel (mkhfiknndh loss msir; mvazi ba websocket/443) ----------

# kcptun rooye UDP mishnvd va be port kontroli rathole (127.0.0.1:control_port) fvrvard mikonad.
# hich tghiiri dar rathole-server/nginx/443 nmidhd; yek masir vrvdi dovom ezafe mikonad.
KCP_SRV_BIN=/usr/local/bin/kcptun-server
KCP_SRV_UNIT=/etc/systemd/system/rathole-kcp-server.service
# mkhzn asli xtaci/kcptun arshiv shode va bainrihaish hazf shdh; az mirvr ossfork estefade mikonim.
KCPTUN_VER_DEF="v20260129"
KCPTUN_BASE_DEF="https://github.com/ossfork/kcptun/releases/download"

install_kcptun(){ # $1=server|client  → nasb bainri dar /usr/local/bin/kcptun-$1
  local role="$1" bin="/usr/local/bin/kcptun-$1" ver="${KCPTUN_VER:-$KCPTUN_VER_DEF}" base="${KCPTUN_BASE:-$KCPTUN_BASE_DEF}" arch tmp url
  [ -x "$bin" ] && return 0
  case "$(uname -m)" in x86_64) arch=amd64 ;; aarch64) arch=arm64 ;; armv7l) arch=armv7 ;; *) die "memari poshtibani nemishavad." ;; esac
  command -v curl >/dev/null 2>&1 || die "curl lazem ast."
  log "download kcptun ${ver} ($role)..."
  tmp="$(rth_mktempd)"
  url="${base}/${ver}/kcptun_linux_${arch}.tar.gz"
  curl -fsSL "$url" -o "$tmp/k.tgz" || { rm -rf "$tmp"; die "download kcptun shekast khord (nskhh/shbkh?)."; }
  tar -xzf "$tmp/k.tgz" -C "$tmp" || { rm -rf "$tmp"; die "baz kardan arshiv kcptun shekast khord."; }
  install -m755 "$tmp/${role}_linux_${arch}" "$bin" || { rm -rf "$tmp"; die "nasb bainri kcptun shekast khord."; }
  rm -rf "$tmp"
  log "kcptun-$role nasb shod: $bin"
}

# profile FEC → "datashard parityshard mode sndwnd rcvwnd"
# balanced: ~30% afzvngi, aadi | lossy: afzvngi bala baraye loss ziad | aggressive: kmtrin ltnsi
kcp_profile(){
  case "${1:-balanced}" in
    balanced)   echo "10 3 fast2 2048 2048" ;;
    lossy)      echo "10 5 fast2 2048 2048" ;;
    aggressive) echo "10 4 fast3 4096 4096" ;;
    *) return 1 ;;
  esac
}

cmd_kcp(){
  need_root; need_bin jq; ensure_state
  local sub="${1:-status}"; shift || true
  case "$sub" in
    on)   cmd_kcp_on "$@" ;;
    off)  cmd_kcp_off ;;
    status) cmd_kcp_status ;;
    show) print_kcp_connect ;;
    *) die "estefade: ratholectl kcp <on [port] [profile]|off|status|show>  (profile: balanced|lossy|aggressive)" ;;
  esac
}

cmd_kcp_on(){
  local port="${1:-443}" profile="${2:-balanced}" ctrl key params ds ps mode sw rw
  echo "$port" | grep -qE '^[0-9]+$' || die "port bayad adad bashad."
  params="$(kcp_profile "$profile")" || die "profile namotabar: $profile (balanced|lossy|aggressive)"
  read -r ds ps mode sw rw <<<"$params"
  ctrl="$(s_get '.control_port')"; case "$ctrl" in ''|null) ctrl=2333 ;; esac
  # kelid mojood ra ngh dar, dar ghir ainsvrt bsaz
  key="$(jq -r '.kcp.key // empty' "$STATE" 2>/dev/null)"
  [ -n "$key" ] || key="$(gen_token)"
  install_kcptun server
  # zkhirh dar state
  local tmp; tmp="$(mktemp)"
  jq --argjson p "$port" --arg k "$key" --argjson c "$ctrl" --arg prof "$profile" \
     --argjson ds "$ds" --argjson ps "$ps" --arg mode "$mode" --argjson sw "$sw" --argjson rw "$rw" \
     '.kcp = {enabled:true, port:$p, key:$k, target:("127.0.0.1:"+($c|tostring)),
              profile:$prof, mtu:1350, sndwnd:$sw, rcvwnd:$rw, datashard:$ds, parityshard:$ps, mode:$mode, crypt:"aes-128"}' \
     "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  gen_kcp_server_unit
  systemctl daemon-reload
  systemctl enable rathole-kcp-server >/dev/null 2>&1
  systemctl restart rathole-kcp-server 2>/dev/null
  if systemctl is-active --quiet rathole-kcp-server; then
    log "kcp-server rooye UDP :$port faal shod → 127.0.0.1:$ctrl (profile: $profile)."
  else
    err "rathole-kcp-server bala niamd; log: journalctl -u rathole-kcp-server -n 30"
  fi
  if [ "$port" = 443 ]; then
    log "estetar: UDP/443 baraye DPI shbih QUIC/HTTP3 didh mishavad (tdakhli ba nginx rooye TCP/443 nadarad)."
  fi
  warn "firewall: port UDP $port ra baz kon (masalan: ufw allow $port/udp , ya Security Group abri)."
  print_kcp_connect
}

gen_kcp_server_unit(){
  local k; k="$(jq -r '.kcp' "$STATE")"
  local port target key mtu sw rw ds ps mode crypt
  port="$(echo "$k" | jq -r '.port')";     target="$(echo "$k" | jq -r '.target')"
  key="$(echo "$k" | jq -r '.key')";       mtu="$(echo "$k" | jq -r '.mtu')"
  sw="$(echo "$k" | jq -r '.sndwnd')";     rw="$(echo "$k" | jq -r '.rcvwnd')"
  ds="$(echo "$k" | jq -r '.datashard')";  ps="$(echo "$k" | jq -r '.parityshard')"
  mode="$(echo "$k" | jq -r '.mode')";     crypt="$(echo "$k" | jq -r '.crypt')"
  cat > "$KCP_SRV_UNIT" <<UNIT
[Unit]
Description=rathole kcp-server (UDP+FEC entry -> rathole control)
After=network.target

[Service]
Type=simple
ExecStart=${KCP_SRV_BIN} -t ${target} -l :${port} -key ${key} -crypt ${crypt} -mode ${mode} -mtu ${mtu} -sndwnd ${sw} -rcvwnd ${rw} -datashard ${ds} -parityshard ${ps} -dscp 46 -nocomp
Restart=always
RestartSec=2
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
UNIT
}

cmd_kcp_off(){
  systemctl disable --now rathole-kcp-server 2>/dev/null || true
  rm -f "$KCP_SRV_UNIT"; systemctl daemon-reload 2>/dev/null || true
  local tmp; tmp="$(mktemp)"
  jq '(.kcp.enabled) = false' "$STATE" > "$tmp" 2>/dev/null && mv "$tmp" "$STATE" || rm -f "$tmp"
  log "kcp-server khamoosh shod. tunnelha az haman masir websocket/443 kar mikonand."
}

cmd_kcp_status(){
  local en; en="$(jq -r '.kcp.enabled // false' "$STATE" 2>/dev/null)"
  if [ "$en" != true ]; then echo "kcp: $(c_y 'khamoosh') (tunnel fali rooye websocket/443)"; return; fi
  local port prof; port="$(jq -r '.kcp.port' "$STATE")"; prof="$(jq -r '.kcp.profile // "balanced"' "$STATE")"
  echo "kcp: $(c_g 'roshan')  UDP :$port → 127.0.0.1:$(s_get '.control_port')  (profile: $prof)"
  [ "$port" = 443 ] && echo "  estetar: UDP/443 ~ QUIC/HTTP3"
  systemctl is-active --quiet rathole-kcp-server && echo "  service: $(c_g 'active')" || echo "  service: $(c_r 'inactive')"
