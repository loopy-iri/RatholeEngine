cmd_game_add(){
  local name="${1:-}" inbound="${2:-}" sni="${3:-}"
  [ -n "$name" ] && [ -n "$inbound" ] && [ -n "$sni" ] || die "estefade: ratholectl game add <name> <node_tls_inbound_port> <sni>"
  echo "$name" | grep -qE '^[a-zA-Z0-9_-]+$' || die "name namotabar."
  is_reserved_name "$name" && die "name '$name' rezerv shode; name-e digari entekhab kon."
  echo "$inbound" | grep -qE '^[0-9]+$' || die "inbound bayad adad bashad."
  # sni mostaghim daroon-e config-e nginx stream neveshte mishavad (gen_stream_conf);
  # hatman ba regex-e hostname mahdood shavad (ejaze-ye '*.' baraye wildcard) ta tzrigh nashavad.
  echo "$sni" | grep -qE '^(\*\.)?[A-Za-z0-9_.-]+$' || die "sni namotabar (faghat harf/adad/nghth/khttirh, ya '*.' baraye wildcard)."
  jq -e --arg n "$name" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null && die "node '$name' vojood darad."
  local dstart dport token node_json
  dstart="$(s_get '.data_port_start')"; dport="$(next_port port "$dstart")"; token="$(gen_token)"
  node_json="$(jq -n --arg n "$name" --argjson p "$dport" --argjson ib "$inbound" --arg t "$token" --arg s "$sni" \
     '{name:$n, port:$p, inbound_port:$ib, token:$t, sni:$s}')"
  jq --argjson node "$node_json" '.nodes += [$node]' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
  log "service game '$name' ezafe shod (SNI=$sni → data 127.0.0.1:$dport , node inbound :$inbound)."
  warn "443 hala stream/SNI shd; L7 fali rooye port dakhli mntghl shod (karbaran path dstnkhvrdh)."
  regenerate
  print_game_install "$name"
}

cmd_game_rm(){
  local name="${1:-}"
  [ -n "$name" ] || die "estefade: ratholectl game rm <name>"
  jq -e --arg n "$name" '.nodes[]|select(.name==$n and .sni!=null)' "$STATE" >/dev/null || die "service game '$name' peyda nashod."
  jq --arg n "$name" '.nodes |= map(select(.name!=$n))' "$STATE" > "$STATE.tmp" && mv "$STATE.tmp" "$STATE"
