}

# ---------- noise: transport-e ramznegari-shode (rathole Noise) rooye instans-e dovom, bedoon nginx/TLS/cert ----------
# yek prose-ye rathole-e dovom (rathole-noise) rooye port-e TCP-e omomi. har node ba 'noise node <name> on'
# be in masir montaghel mishavad; service-e an az server.toml be noise-server.toml jabeja mishavad.
NOISE_UNIT="/etc/systemd/system/${NOISE_SVC}.service"

ensure_noise_unit(){
  # unit-e systemd baraye instans-e dovom (agar hanooz sakhte nashode).
  [ -f "$NOISE_UNIT" ] && return 0
  cat > "$NOISE_UNIT" <<UNIT
[Unit]
Description=rathole noise server (encrypted tunnel, Iran panel)
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/rathole ${NOISE_TOML}
Restart=always
RestartSec=2
Environment=RUST_LOG=info

[Install]
WantedBy=multi-user.target
UNIT
  systemctl daemon-reload 2>/dev/null || true
  log "unit-e $NOISE_SVC sakhte shod."
}

cmd_noise(){
  need_root; need_bin jq; ensure_state
  local sub="${1:-status}"; shift || true
  case "$sub" in
    on)
      local port="${1:-}"; port="${port:-2334}"
      echo "$port" | grep -qE '^[0-9]+$' || die "port bayad adad bashad."
      [ "$port" = "443" ] && die "port 443 baraye masir-e TLS/game rezerv ast; port-e digari (masalan 2334) bede."
      local internal; internal="$(jq -r '.internal_port // 8443' "$STATE" 2>/dev/null)"
      [ "$port" = "$internal" ] && die "port $port ba internal_port-e game/SNI tadakhol darad; port-e digari bede."
      noise_genkey
      state_set '.noise_port' "$port" num
      state_set '.noise_pattern' "${NOISE_PATTERN_DEFAULT}"
      ensure_noise_unit
      gen_noise_server_toml
      systemctl enable "$NOISE_SVC" >/dev/null 2>&1 || true
      warn "firewall: port TCP $port ra baz kon (masalan: ufw allow $port/tcp)."
      command -v ufw >/dev/null 2>&1 && ufw allow "$port/tcp" >/dev/null 2>&1 || true
      log "halat noise (ramznegari-shode) faal shod: rathole-noise rooye port-e omomi $port."
      regenerate
      systemctl restart "$NOISE_SVC" 2>/dev/null && log "$NOISE_SVC start shod." || err "start-e $NOISE_SVC nashod; log: journalctl -u $NOISE_SVC -n 30"
      print_noise_connect "${1:-}"
      ;;
    off)
      # transport-e hame node-ha ra hazf kon (nabvdan = ws), service ra khamoosh kon, state-key-haye noise ra hazf kon.
      local tmp; tmp="$(mktemp)"
      jq 'del(.nodes[].transport) | del(.noise_port,.noise_pattern,.noise_privkey,.noise_pubkey)' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
      systemctl disable --now "$NOISE_SVC" 2>/dev/null || true
      rm -f "$NOISE_UNIT"; systemctl daemon-reload 2>/dev/null || true
      rm -f "$NOISE_TOML"
      log "halat noise khamoosh shod (rathole-noise hazf shod). node-haye noise be ws/443 bargardande shodand."
      regenerate
      ;;
    node)
      local name="${1:-}" act="${2:-}"
      echo "$name" | grep -qE '^[A-Za-z0-9_-]{1,40}$' || die "name-e node namotabar ast."
      jq -e --arg n "$name" '.nodes[] | select(.name==$n)' "$STATE" >/dev/null 2>&1 || die "node '$name' peyda nashod."
      case "$act" in
        on)
          local np; np="$(jq -r '.noise_port // empty' "$STATE" 2>/dev/null)"
          [ -n "$np" ] && [ "$np" != null ] || die "aval halat noise ra roshan kon: ratholectl noise on [port]"
          local tmp; tmp="$(mktemp)"; jq --arg n "$name" '(.nodes[] | select(.name==$n) | .transport) |= "noise"' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
          log "node '$name' be masir-e noise montaghel shod."
          regenerate
          print_noise_connect "$name"
          ;;
        off)
          local tmp; tmp="$(mktemp)"; jq --arg n "$name" 'del(.nodes[] | select(.name==$n) | .transport)' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
          log "node '$name' be masir-e ws/443 bargasht."
          regenerate
          ;;
        *) die "estefade: ratholectl noise node <name> <on|off>" ;;
      esac
      ;;
    status)
      local np; np="$(jq -r '.noise_port // empty' "$STATE" 2>/dev/null)"
      if [ -n "$np" ] && [ "$np" != null ]; then
        local cnt; cnt="$(jq -r '[.nodes[] | select(.transport=="noise")] | length' "$STATE" 2>/dev/null)"
        echo "noise (ramznegari-shode): $(c_g 'roshan')  rathole-noise rooye port-e omomi $np  (node-haye noise: ${cnt:-0})"
        # list-e esm-e node-haye noise (baraye parse-e hub / namayesh-e per-node)
        local nlist; nlist="$(jq -r '[.nodes[] | select(.transport=="noise") | .name] | join(", ")' "$STATE" 2>/dev/null)"
        [ -n "$nlist" ] && echo "  node-haye noise: $nlist"
        command -v ss >/dev/null 2>&1 && { ss -ltnH "sport = :$np" 2>/dev/null | grep -q . && echo "  gvshdadn TCP:$np: $(c_g 'blh')" || echo "  gvshdadn TCP:$np: $(c_r 'khir')"; }
        command -v systemctl >/dev/null 2>&1 && { systemctl is-active --quiet "$NOISE_SVC" && echo "  $NOISE_SVC: $(c_g 'active')" || echo "  $NOISE_SVC: $(c_r 'inactive')"; }
      else
        echo "noise (ramznegari-shode): $(c_y 'khamoosh')  (tunnelha rooye websocket/443 ba TLS)"
      fi
      ;;
    show) print_noise_connect "${1:-}" ;;
    *) die "estefade: ratholectl noise <on [port]|off|node <name> on|off|status|show [name]>" ;;
  esac
}

print_noise_connect(){
  local np pub pat ip
  np="$(jq -r '.noise_port // empty' "$STATE" 2>/dev/null)"
  [ -n "$np" ] && [ "$np" != null ] || { warn "noise khamoosh ast; aval: ratholectl noise on [port]"; return; }
  pub="$(jq -r '.noise_pubkey // empty' "$STATE" 2>/dev/null)"
  pat="$(jq -r '.noise_pattern // empty' "$STATE" 2>/dev/null)"; [ -n "$pat" ] && [ "$pat" != null ] || pat="$NOISE_PATTERN_DEFAULT"
  ip="$(curl -fsS4 https://api.ipify.org 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}')"
  echo
  echo "$(c_y '──────── faalsazi halat noise (ramznegari-shode) rooye node kharej ────────')"
  echo "rooye node in ra bezan (masir tunnel ba Noise ramznegari mishavad — bedoon TLS/cert):"
  echo "  ratholenode noise on ${ip:-<IRAN_IP>}:${np} ${pub:-<PUBKEY>} ${pat}"
  echo
  echo "bazgsht be halat TLS (websocket/443):  ratholenode noise off"
  echo "$(c_y '──────────────────────────────────────────────────')"
  echo "nokte: kelid-e omomi bala qabel-e enteshar ast; kelid-e khsvsi rooye Iran mimanad. firewall port $np/tcp bayad baz bashad."
}

# ---------- doctor: barresi slamt ----------
cmd_doctor(){

  need_bin jq; ensure_state
  local domain ctrl fake ok=0 bad=0
  domain="$(s_get '.domain')"; ctrl="$(s_get '.control_port')"; fake="$(s_get '.fake_port')"
  chk(){ if eval "$2" >/dev/null 2>&1; then printf '  %s %s\n' "$(c_g 'OK ')" "$1"; ok=$((ok+1)); else printf '  %s %s\n' "$(c_r 'FAIL')" "$1"; bad=$((bad+1)); fi; }

  echo "$(c_g '== barresi serviceha ==')"
  chk "rathole-server faal ast"        "systemctl is-active --quiet $RATHOLE_SVC"
  chk "nginx faal ast"                  "systemctl is-active --quiet nginx"
  chk "config nginx motabar ast (nginx -t)" "nginx -t"

  echo "$(c_g '== barresi pvrthai lvkal ==')"
  chk "kntrl rathole rooye 127.0.0.1:$ctrl gvsh midahad" \
      "ss -ltnH 'sport = :$ctrl' | grep -q ."
  chk "sait fik rooye 127.0.0.1:$fake gvsh midahad" \
      "ss -ltnH 'sport = :$fake' | grep -q ."
  jq -r '.nodes[] | [.name,(.port|tostring)] | @tsv' "$STATE" |
  while IFS=$'\t' read -r n p; do
    if ss -ltnH "sport = :$p" | grep -q .; then
      printf '  %s node %s rooye port %s amade ast\n' "$(c_g 'OK ')" "$n" "$p"
    else
      printf '  %s node %s rooye port %s gvsh nmidhd (klaint node vsl nist?)\n' "$(c_y 'WARN')" "$n" "$p"
    fi
  done

  echo "$(c_g '== tst tmaiz sait fik / channel kontroli (az rooye hamin server) ==')"
  if command -v curl >/dev/null 2>&1; then
    local root_code ws_out
    root_code="$(curl -s -o /dev/null -w '%{http_code}' -k "https://$domain/" --resolve "$domain:443:127.0.0.1" 2>/dev/null || echo 000)"
    echo "  drkhvast aadi be / → kd HTTP: $(c_y "$root_code") (bayad sait fik/panel ra bdhd)"
    ws_out="$(curl -s -o /dev/null -w '%{http_code}' -k \
      -H 'Connection: Upgrade' -H 'Upgrade: websocket' \
      -H 'Sec-WebSocket-Version: 13' -H 'Sec-WebSocket-Key: dGhlIHNhbXBsZQ==' \
      "https://$domain/" --resolve "$domain:443:127.0.0.1" 2>/dev/null || echo 000)"
    echo "  drkhvast websocket be / → kd HTTP: $(c_y "$ws_out") (101=rthvl, ghir an=be fik rfth)"
  else
    warn "curl nasb nist; tst HTTP rad shod."
  fi
  echo
  echo "$(c_g "khlash:") OK=$ok  FAIL=$bad"
}

