# beroozresani-e kamel az GitHub (akharin Release): install.sh ra migirad va --update mizanad.
# install.sh khodesh snapshot + health-check + rollback-e khodkar ra (az tarigh bootstrap→update.sh) ejra mikonad.
# mirror-haye ghproxy baraye dor-zadan-e filtering-e Iran (hamsan-e install-panel.sh).
cmd_update(){
  need_root
  command -v curl >/dev/null 2>&1 || die "curl lazem ast (apt install -y curl)."
  local gh="${RATHOLE_GH:-loopy-iri/RatholeEngine}" rel="${RATHOLE_RELEASE:-latest}"
  local path; if [ "$rel" = "latest" ]; then path="releases/latest/download/install.sh"; else path="releases/download/${rel}/install.sh"; fi
  local mirrors=("" "https://ghproxy.net/" "https://gh-proxy.com/" "https://mirror.ghproxy.com/")
  local tmp m ok=0; tmp="$(mktemp)"
  log "download install.sh az GitHub Release: $gh ($rel)..."
  for m in "${mirrors[@]}"; do
    if curl -fSL --retry 2 --connect-timeout 20 "${m}https://github.com/${gh}/${path}" -o "$tmp" 2>/dev/null; then ok=1; break; fi
    [ -n "$m" ] && warn "in mirror javab nadad, badi..."
  done
  [ "$ok" -eq 1 ] || { rm -f "$tmp"; die "download install.sh az hameye mirror-ha shekast khord (filtering/slug/release ra barresi kon)."; }
  log "ejra-ye update-e kamel (snapshot + health-check + rollback-e khodkar)..."
  RATHOLE_GH="$gh" RATHOLE_RELEASE="$rel" bash "$tmp" --update
  local rc=$?
  rm -f "$tmp"
  return "$rc"
}

usage(){
  cat <<USAGE
ratholectl — mdirit tunnel rathole mvltilvkishn

dstvrha:
  init                         tanzim damnh/gvahi/portha
  add <name> <inbound> [api]   afzoodan node (api = port mdirit ekhtiari)
  rm <name>                    hazf node
  ls                           list nodeha
  set <key> <value>            taghir tanzimat srasri (domain/fullchain/key/nginx-conf/fake-port/sub-port/control-port)
  info                         namayesh damnh/gvahi/enghza va damnhhai SNI (baraye panel)
  cert <domain> [email]        grftn gvahi Let's Encrypt + tanzim damnh asli (ghir-taamoli)

  edit <name> [--inbound N] [--api-port N|off]   virayesh yek node
  rename <old> <new>           taghir name/masir node
  rotate <name>                chrkhsh token(ha)i node
  show <name>                  namayesh jzyiat va dstvr nasb node
  regen                        baztolid configha va reload
  backup [file]                sakht backup az state (nodeha/tokenha)
  restore <file>               restore az backup + baztolid
  token <name>                 chap dstvr nasb node
  doctor                       barresi slamt system va tmaiz sait fik/rthvl
  tune                         eemal BBR + limithaye system/nginx (rfa 502 zir burst)
  fakeweb <start|stop|rm|status> [port]   sait fik pishfarz rooye fake_port (rfa 502 rooye / dar srvrhai rlh)
  hub <on [port]|off|status>   ghrardadn panel web psht nginx zir haman damnh (/hub/)
  kcp <on [port] [profile]|off|status|show>   tunnel UDP+FEC ba estetar (port 443=QUIC; profile: balanced/lossy/aggressive)
  plain <on [port]|off|status|show>   tunnel-e websocket bedoon-e TLS (listener HTTP rooye port jda, masalan 8880)
  noise <on [port]|off|node <name> on|off|status|show>   tunnel-e ramznegari-shode (Noise) rooye instans-e dovom (bedoon TLS/cert, port omomi masalan 2334)
  game add <name> <inbound> <sni>   service game (SNI rooye 443, TLS rooye node)

  game rm <name> | ls | show <name> | cert <sni>   mdirit service game va gvahi
  restart                      restart kamel rathole-server (tunnelha lhzhai ghat)
  enable                       faalsazi va start rathole-server
  update                       beroozresani-e kamel az GitHub (akharin Release; snapshot + rollback-e khodkar)
  menu                         mnvi taamoli (pishfarz)
USAGE
}

main(){
  local cmd="${1:-menu}"; shift || true
  case "$cmd" in
    init)   cmd_init "$@" ;;
    add)
      # aval flg-ha ra jodkon, sps positional-ha (name inbound) — ta `add name --api-port N`
      # eshtebahan inbound='--api-port' nashavad.
      local api="" pos=()
      while [ $# -gt 0 ]; do
        case "$1" in
          --api-port) api="${2:-}"; shift 2 || shift;;
          *) pos+=("$1"); shift;;
        esac
      done
      cmd_add "${pos[0]:-}" "${pos[1]:-}" "$api" ;;
    rm)     cmd_rm "${1:-}" ;;
    ls)     cmd_ls ;;
    set)    cmd_set "${1:-}" "${2:-}" ;;
    info)   cmd_info ;;
    cert)   cmd_cert "${1:-}" "${2:-}" ;;
    certs)  cmd_certs ;;
    domain) cmd_domain "$@" ;;
    recover) cmd_recover ;;
    edit)   cmd_edit "$@" ;;

    rename) cmd_rename "${1:-}" "${2:-}" ;;
    rotate) cmd_rotate "${1:-}" ;;
    show)   cmd_show "${1:-}" ;;
    regen)  regenerate ;;
    backup) cmd_backup "${1:-}" ;;
    restore) cmd_restore "${1:-}" ;;
    token)  print_node_install "${1:-}" ;;
    doctor) cmd_doctor ;;
    tune)   cmd_tune ;;
    fakeweb) cmd_fakeweb "${1:-}" "${2:-}" ;;
    hub)    cmd_hub "${1:-}" "${2:-}" ;;
    kcp)    cmd_kcp "$@" ;;
    plain)  cmd_plain "${1:-}" "${2:-}" ;;
    noise)  cmd_noise "$@" ;;

    game)   cmd_game "$@" ;;
    restart) need_root; systemctl restart "$RATHOLE_SVC" && log "$RATHOLE_SVC restart shod (hame tunnelha lhzhai ghat shdnd)." ;;
    enable) need_root; systemctl enable --now "$RATHOLE_SVC"; log "$RATHOLE_SVC faal shod." ;;
    update) cmd_update ;;
    menu)   menu ;;
    -h|--help|help) usage ;;
    *) err "dstvr nashenakhte: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
