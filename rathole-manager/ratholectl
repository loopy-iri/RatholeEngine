# ---------- list hameye gvahiha (letsencrypt + gvahi asli + extra + SNI) baraye panel ----------
cmd_certs(){
  need_bin jq; ensure_state
  local active mfc le=/etc/letsencrypt/live
  active="$(s_get '.domain')"; mfc="$(s_get '.cert_fullchain')"
  _exp(){ local f="$1" e="-"; command -v openssl >/dev/null 2>&1 && e="$(openssl x509 -enddate -noout -in "$f" 2>/dev/null | cut -d= -f2)"; echo "${e:-?}"; }
  echo "DOMAIN|EXPIRY|ACTIVE|SNI"
  local seen_active=0 d dom fc is_active is_sni
  if [ -d "$le" ]; then
    for d in "$le"/*/; do
      [ -d "$d" ] || continue
      dom="$(basename "$d")"; [ "$dom" = "README" ] && continue
      fc="$d/fullchain.pem"; [ -f "$fc" ] || continue
      if [ "$dom" = "$active" ]; then is_active=yes; seen_active=1
      elif jq -e --arg x "$dom" '(.extra_domains // [])[]|select(.domain==$x)' "$STATE" >/dev/null 2>&1; then is_active=yes
      else is_active=no; fi
      if jq -e --arg sn "$dom" '.nodes[]|select(.sni==$sn)' "$STATE" >/dev/null 2>&1; then is_sni=yes; else is_sni=no; fi
      echo "${dom}|$(_exp "$fc")|${is_active}|${is_sni}"
    done
  fi
  if [ "$seen_active" -eq 0 ] && [ -n "$active" ] && [ "$active" != null ] && [ -f "$mfc" ]; then
    echo "${active}|$(_exp "$mfc")|yes|no"
  fi
}

# ---------- grftn gvahi + tanzim damnh (ghir-taamoli, baraye panel) ----------
# estefade: ratholectl cert <domain> [email]   (email khali = bedoon email sabt mishavad)
cmd_cert(){
  need_root; need_bin jq; ensure_state
  local domain="${1:-}" email="${2:-}"
  [ -n "$domain" ] || die "estefade: ratholectl cert <domain> [email]"
  echo "$domain" | grep -qE '^[A-Za-z0-9_.-]+$' || die "damnh namotabar."
  command -v certbot >/dev/null 2>&1 || die "certbot nasb nist."
  warn "niaz: DNS $domain be hamin server asharh konad va port 80 azad bashad."
  local was_active=0
  systemctl is-active --quiet nginx && { was_active=1; systemctl stop nginx; }
  local args=(certonly --standalone --non-interactive --agree-tos -d "$domain")
  if [ -n "$email" ]; then args+=(-m "$email"); else args+=(--register-unsafely-without-email); fi
  if certbot "${args[@]}"; then
    local fc="/etc/letsencrypt/live/${domain}/fullchain.pem"
    local key="/etc/letsencrypt/live/${domain}/privkey.pem"
    log "gvahi grfth shod: /etc/letsencrypt/live/${domain}/"
    # tanzim damnh va gvahi be onvan damnh asli + baztolid nginx/server.toml
    state_set '.domain' "$domain" str
    state_set '.cert_fullchain' "$fc" str
    state_set '.cert_key' "$key" str
    [ "$was_active" -eq 1 ] && systemctl start nginx || true
    regenerate
    log "damnh asli be '$domain' taghir kard va nginx baztolid shod."
  else
    [ "$was_active" -eq 1 ] && systemctl start nginx || true
    die "grftn gvahi shekast khord (DNS? port 80 bsth? filtr?)."
  fi
}

# ---------- recover: bazgasht foori be config salem tak-damnh ----------
# hameye domainhaye ezafi ra hazf va config asli ra baztolid mikonad (baraye rafe khrabi nginx).
cmd_recover(){
  need_root; need_bin jq; ensure_state
  warn "recover: hazf hameye domainhaye ezafi va baztolid config tak-damnh (halat salem ghabli)."
  local tmp; tmp="$(mktemp)"
  jq 'del(.extra_domains)' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  regenerate
  local out; out="$(jq -r '.nginx_conf // empty' "$STATE" 2>/dev/null)"; [ -n "$out" ] || out="$NGINX_CONF"
  if command -v nginx >/dev/null 2>&1 && ! nginx -t >/dev/null 2>&1; then
    if [ -f "$out.rathole-good.bak" ]; then
      cp -a "$out.rathole-good.bak" "$out"; nginx -t >/dev/null 2>&1 && systemctl reload nginx 2>/dev/null || true
      warn "config known-good bazgardande shod."
    fi
  fi
  log "recover tamam shod. barresi: ratholectl doctor"
}

# ---------- mdirit chand damnh hamzaman rooye yek server Iran ----------
cmd_domain(){
  need_root; need_bin jq; ensure_state
  local sub="${1:-ls}"; shift || true
  case "$sub" in
    add) cmd_domain_add "$@" ;;
    primary) cmd_domain_primary "$@" ;;
    rm)  cmd_domain_rm "${1:-}" ;;
    ls)  cmd_domain_ls ;;
    *) die "estefade: ratholectl domain <add|primary|rm|ls> ..." ;;
  esac

}

cmd_domain_add(){
  local domain="${1:-}"; shift || true
  [ -n "$domain" ] || die "estefade: ratholectl domain add <domain> [--certbot] [--email E] [--fullchain F] [--key K]"
  echo "$domain" | grep -qE '^[A-Za-z0-9_.-]+$' || die "damnh namotabar."
  local use_certbot=0 email="" fc="" key=""
  while [ $# -gt 0 ]; do case "$1" in
    --certbot) use_certbot=1; shift;;
    --email) email="${2:-}"; shift 2;;
    --fullchain) fc="${2:-}"; shift 2;;
    --key) key="${2:-}"; shift 2;;
    *) shift;;
  esac; done
  [ "$domain" = "$(s_get '.domain')" ] && die "in hamon damnh asli ast; ba 'set domain' avazsh kon na 'domain add'."
  if [ "$use_certbot" -eq 1 ]; then
    command -v certbot >/dev/null 2>&1 || die "certbot nasb nist."
    warn "niaz: DNS $domain be hamin server + port 80 azad."
    local was=0; systemctl is-active --quiet nginx && { was=1; systemctl stop nginx; }
    local args=(certonly --standalone --non-interactive --agree-tos -d "$domain")
    if [ -n "$email" ]; then args+=(-m "$email"); else args+=(--register-unsafely-without-email); fi
    if certbot "${args[@]}"; then
      fc="/etc/letsencrypt/live/${domain}/fullchain.pem"; key="/etc/letsencrypt/live/${domain}/privkey.pem"
      [ "$was" -eq 1 ] && systemctl start nginx || true
    else
      [ "$was" -eq 1 ] && systemctl start nginx || true
      die "grftn gvahi shekast khord (DNS? port 80?)."
    fi
  fi
  [ -n "$fc" ] || fc="/etc/letsencrypt/live/${domain}/fullchain.pem"
  [ -n "$key" ] || key="/etc/letsencrypt/live/${domain}/privkey.pem"
  # agar gvahi ekhtsasi in damnh nist (masalan CNAME posht-e Cloudflare ke TLS-ash ba CF anjam mishavad),
  # az gvahi damnh asli estefade kon ta baz ham yek server-block ba server_name daghigh sakhte shavad
  # (ke rooye Host-e daghigh az default_server-e site-haye digar mesl pasteshare barande ast).
  if [ ! -f "$fc" ] || [ ! -f "$key" ]; then
    local mfc mkey; mfc="$(s_get '.cert_fullchain')"; mkey="$(s_get '.cert_key')"
    if [ -f "$mfc" ] && [ -f "$mkey" ]; then
      warn "gvahi ekhtsasi '$domain' nist; az gvahi damnh asli estefade shod (monaseb baraye CNAME posht-e Cloudflare/Full)."
      fc="$mfc"; key="$mkey"
    else
      die "gvahi peyda nashod: $fc / $key (aval ba --certbot begir ya masir bede)."
    fi
  fi
  local tmp; tmp="$(mktemp)"
  jq --arg d "$domain" --arg fc "$fc" --arg k "$key" \
     '.extra_domains = ((.extra_domains // []) | map(select(.domain!=$d)) + [{domain:$d,fullchain:$fc,key:$k}])' \
     "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  log "damnh '$domain' ezafe shod (gvahi: $fc)."
  regenerate
}

cmd_domain_primary(){
  local newd="${1:-}"; shift || true
  [ -n "$newd" ] || die "estefade: ratholectl domain primary <domain> [--certbot] [--email E] [--fullchain F] [--key K]"
  echo "$newd" | grep -qE '^[A-Za-z0-9_.-]+$' || die "damnh namotabar."
  local cur ofc okey; cur="$(s_get '.domain')"; ofc="$(s_get '.cert_fullchain')"; okey="$(s_get '.cert_key')"
  [ "$newd" = "$cur" ] && die "damnh '$newd' hamin alan asli ast."
  local use_certbot=0 email="" fc="" key=""
  while [ $# -gt 0 ]; do case "$1" in
    --certbot)   use_certbot=1; shift;;
    --email)     email="${2:-}"; shift 2;;
    --fullchain) fc="${2:-}"; shift 2;;
    --key)       key="${2:-}"; shift 2;;
    *) shift;;
  esac; done
  # agar damnh jadid ghablan extra bood, gvahi khodesh ra estefade kon
  if [ -z "$fc" ] && [ "$use_certbot" -eq 0 ]; then
    local exfc exkey
    exfc="$(jq -r --arg d "$newd" '(.extra_domains // [])[]|select(.domain==$d)|.fullchain' "$STATE" 2>/dev/null)"
    if [ -n "$exfc" ] && [ "$exfc" != null ]; then
      fc="$exfc"; exkey="$(jq -r --arg d "$newd" '(.extra_domains // [])[]|select(.domain==$d)|.key' "$STATE" 2>/dev/null)"
      [ "$exkey" != null ] && key="$exkey"
    fi
  fi
  if [ "$use_certbot" -eq 1 ]; then
    command -v certbot >/dev/null 2>&1 || die "certbot nasb nist."
    warn "niaz: DNS $newd be hamin server + port 80 azad."
    local was=0; systemctl is-active --quiet nginx && { was=1; systemctl stop nginx; }
    local args=(certonly --standalone --non-interactive --agree-tos -d "$newd")
    if [ -n "$email" ]; then args+=(-m "$email"); else args+=(--register-unsafely-without-email); fi
    if certbot "${args[@]}"; then
      fc="/etc/letsencrypt/live/${newd}/fullchain.pem"; key="/etc/letsencrypt/live/${newd}/privkey.pem"
      [ "$was" -eq 1 ] && systemctl start nginx || true
    else
      [ "$was" -eq 1 ] && systemctl start nginx || true
      die "grftn gvahi shekast khord (DNS? port 80?)."
    fi
  fi
  [ -n "$fc" ]  || fc="/etc/letsencrypt/live/${newd}/fullchain.pem"
  [ -n "$key" ] || key="/etc/letsencrypt/live/${newd}/privkey.pem"
  { [ -f "$fc" ] && [ -f "$key" ]; } || die "gvahi damnh jadid peyda nashod: $fc / $key (aval --certbot ya masir bede)."
  # taghir atomic: damnh ghabli -> extra (agar gvahi darad), damnh jadid -> asli, va az extra hazf
  local tmp; tmp="$(mktemp)"
  jq --arg nd "$newd" --arg nfc "$fc" --arg nk "$key" \
     --arg od "$cur" --arg ofc "$ofc" --arg okey "$okey" '
     (.extra_domains // []) as $ex
     | ($ex | map(select(.domain != $nd and .domain != $od))) as $rest
     | (if ($ofc|length) > 0 then $rest + [{domain:$od, fullchain:$ofc, key:$okey}] else $rest end) as $withold
     | .extra_domains = $withold
     | .domain = $nd | .cert_fullchain = $nfc | .cert_key = $nk
     ' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  log "damnh asli be '$newd' taghir krd. damnh ghabli '$cur' be extra montaghel shod va hamchenan faal ast."
  warn "node-haye ghadimi ba $cur:443 bedoon ghati kar mikonand; damnh jadid $newd ham az hamin lahze faal ast."
  regenerate
}

cmd_domain_rm(){
  local domain="${1:-}"
  [ -n "$domain" ] || die "estefade: ratholectl domain rm <domain>"
  jq -e --arg d "$domain" '(.extra_domains // [])[]|select(.domain==$d)' "$STATE" >/dev/null 2>&1 || die "damnh ezafi '$domain' peyda nashod."
  local tmp; tmp="$(mktemp)"
  jq --arg d "$domain" '.extra_domains = ((.extra_domains // []) | map(select(.domain!=$d)))' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  log "damnh '$domain' hazf shod."
  regenerate
}

cmd_domain_ls(){
  need_bin jq; ensure_state
  echo "DOMAIN|FULLCHAIN|KEY|PRIMARY"
  echo "$(s_get '.domain')|$(s_get '.cert_fullchain')|$(s_get '.cert_key')|yes"
  jq -r '(.extra_domains // [])[] | [.domain,.fullchain,.key,"no"] | join("|")' "$STATE" 2>/dev/null || true
