# ---------- L4 tst (stream+SNI) mvazi rooye port jda ----------
ensure_stream_include(){
  local nc=/etc/nginx/nginx.conf
  grep -qE 'include[[:space:]]+/etc/nginx/stream\.d/\*\.conf' "$nc" && { mkdir -p /etc/nginx/stream.d; return 0; }
  if grep -qE '^[[:space:]]*stream[[:space:]]*\{' "$nc"; then
    warn "blak stream az ghabl dar nginx.conf hst. in kht ra dasti dakhlsh bgzar:"
    warn "    include /etc/nginx/stream.d/*.conf;"
    mkdir -p /etc/nginx/stream.d
    return 0
  fi
  cp -a "$nc" "$nc.l4.bak"
  mkdir -p /etc/nginx/stream.d
  printf '\nstream {\n    include /etc/nginx/stream.d/*.conf;\n}\n' >> "$nc"
  log "blak stream be nginx.conf ezafe shod (backup: $nc.l4.bak)."
}

# ratholectl game add <name> <node_tls_inbound_port> <sni>
cmd_game(){
  need_root; need_bin jq; ensure_state
