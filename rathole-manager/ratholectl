# tvlid config stream (SNI → node passthrough; default → http dakhli)
gen_stream_conf(){
  local internal="$1"
  mkdir -p /etc/nginx/stream.d
  {
    echo "# tvlid khodkar tvst ratholectl — stream/SNI (servicehaye game)"
    echo "map \$ssl_preread_server_name \$rh_stream_backend {"
    echo "    default   127.0.0.1:${internal};"
    jq -r '.nodes[] | select(.sni != null) | [.sni,(.port|tostring)] | @tsv' "$STATE" |
    while IFS=$'\t' read -r sni p; do
      printf '    %-28s 127.0.0.1:%s;\n' "$sni" "$p"
    done
    echo "}"
    echo "server {"
    echo "    listen 443;"
    echo "    ssl_preread on;"
    echo "    proxy_pass \$rh_stream_backend;"
    echo "    proxy_timeout 1h;"
    echo "    proxy_connect_timeout 3s;"
    echo "}"
  } > "$STREAM_CONF"
}

# ---------- regenerate + reload ----------
regenerate(){
  need_root
  # snapshot-e known-good az DO file (http + stream) GHABL az tvlid, ta agar nginx -t
  # shekast khord betavanim har DO ra bargardanim (na faghat http).
  local out; out="$(jq -r '.nginx_conf // empty' "$STATE" 2>/dev/null)"; [ -n "$out" ] || out="$NGINX_CONF"
  local pre_http_bak="" pre_stream_bak=""
  if command -v nginx >/dev/null 2>&1 && nginx -t >/dev/null 2>&1; then
    # config-e fali salem ast → az an snapshot begir (baraye rollback-e in regen)
    [ -f "$out" ] && { pre_http_bak="$(rth_mktemp)"; cp -a "$out" "$pre_http_bak"; }
    [ -f "$STREAM_CONF" ] && { pre_stream_bak="$(rth_mktemp)"; cp -a "$STREAM_CONF" "$pre_stream_bak"; }
  fi
  gen_server_toml
  gen_nginx_conf
  log "configha tvlid shdnd ($SERVER_TOML , $out)."
  if command -v nginx >/dev/null 2>&1; then
    if nginx -t 2>/tmp/nginx_test.log; then
      systemctl reload nginx || systemctl restart nginx
      log "nginx reload shod."
      cp -a "$out" "$out.rathole-good.bak" 2>/dev/null || true
      [ -f "$STREAM_CONF" ] && cp -a "$STREAM_CONF" "$STREAM_CONF.rathole-good.bak" 2>/dev/null || true
      # agar stream hazf shode (bedoon SNI), backup-e bayat ra ham pak kon
      [ -f "$STREAM_CONF" ] || rm -f "$STREAM_CONF.rathole-good.bak" 2>/dev/null
    else
      err "nginx -t khata dad; reload nashod:"; cat /tmp/nginx_test.log >&2
      # rollback-e har DO file (http + stream) be akharin halat-e known-good
      local restored=0
      if [ -n "$pre_http_bak" ] && [ -f "$pre_http_bak" ]; then cp -a "$pre_http_bak" "$out"; restored=1
      elif [ -f "$out.rathole-good.bak" ]; then cp -a "$out.rathole-good.bak" "$out"; restored=1; fi
      if [ -n "$pre_stream_bak" ] && [ -f "$pre_stream_bak" ]; then cp -a "$pre_stream_bak" "$STREAM_CONF"; restored=1
      elif [ -f "$STREAM_CONF.rathole-good.bak" ]; then cp -a "$STREAM_CONF.rathole-good.bak" "$STREAM_CONF"; restored=1
      else
        # stream-e known-good vojood nadasht (masalan awalin regen ba SNI-ye kharab) → file-e kharab ra bardar
        [ -f "$STREAM_CONF" ] && { rm -f "$STREAM_CONF"; restored=1; }
      fi
      if [ "$restored" -eq 1 ]; then
        err "config ghabli bazgardande shod (nginx salem mimanad)."
        nginx -t >/dev/null 2>&1 && { systemctl reload nginx 2>/dev/null || true; }
      else
        err "hich config-e known-good baraye bazgardandan nabood; nginx dast-nakhorde mimanad."
      fi
    fi
  fi
  if systemctl is-active --quiet "$RATHOLE_SVC"; then
    log "server.toml berooz shd; rathole khodesh hot-reload mikonad (tunnelhaye faal ghat nmishvnd)."
  else
    systemctl start "$RATHOLE_SVC" 2>/dev/null && log "$RATHOLE_SVC start shod." || \
      err "ntvanstm $RATHOLE_SVC ra start knm (shaid hnvz enable nashode)."
  fi
  # instans-e noise (agar roshan bashad): noise-server.toml ra besaz va service ra restart kon.
  local nport; nport="$(jq -r '.noise_port // empty' "$STATE" 2>/dev/null)"
  if [ -n "$nport" ] && [ "$nport" != null ]; then
    # unit ra motmaen shv vojood darad — baad-e restore-e panel roo server-e taze
    # mumken ast noise dar state bashad ama unit-e systemd sakhte nashode bashad.
    ensure_noise_unit
    gen_noise_server_toml
    log "noise-server.toml berooz shd ($NOISE_TOML)."
    systemctl enable "$NOISE_SVC" >/dev/null 2>&1 || true
    if systemctl list-unit-files 2>/dev/null | grep -q "^${NOISE_SVC}.service"; then
      # taghir-e list-e service-ha → restart amn-tar az reload (config_watcher list-e service ra dubare mikhanad ama restart motmaen-tar).
      systemctl restart "$NOISE_SVC" 2>/dev/null && log "$NOISE_SVC restart shod." || \
        err "ntvanstm $NOISE_SVC ra restart knm."
    fi
  fi
}

# ---------- chap dstvr nasb node ----------
print_node_install(){
  need_bin jq; ensure_state
  local name="$1" domain ctrl node token inbound aib at
  domain="$(s_get '.domain')"
  node="$(jq -c --arg n "$name" '.nodes[]|select(.name==$n)' "$STATE")"
  [ -n "$node" ] || die "node '$name' peyda nashod."
  token="$(echo "$node" | jq -r '.token')"
  inbound="$(echo "$node" | jq -r '.inbound_port')"
  echo
  echo "$(c_y '──────── dstvr nasb rooye node kharej ────────')"
  printf 'sudo bash install-node.sh --server %s:443 --name %s \\\n' "$domain" "$name"
  printf '     --token %s --inbound-port %s' "$token" "$inbound"
  aib="$(echo "$node" | jq -r '.api_inbound_port // empty')"
  if [ -n "$aib" ]; then
    at="$(echo "$node" | jq -r '.api_token')"
    printf ' \\\n     --api-token %s --api-inbound-port %s' "$at" "$aib"
    echo
    local alp; alp="$(echo "$node" | jq -r '.api_local_port')"
    echo "$(c_y "dar panel: adres node ra 127.0.0.1 va port API ra ${alp} bgzar.")"
  else
    echo
  fi
  echo "$(c_y '────────────────────────────────────────')"
  echo "rooye node yek inbound VLESS+WS bsaz: path=/$name , listen=127.0.0.1 , port=$inbound , TLS=off"
}

# ---------- abzarhaye taghir dar tvl zman ----------
state_set(){ # $1=jqpath $2=value $3=type(str|num)
  local tmp; tmp="$(mktemp)"
  if [ "${3:-str}" = num ]; then
    echo "$2" | grep -qE '^[0-9]+$' || die "meghdar bayad adad bashad: $2"
    jq "$1 = ($2)" "$STATE" > "$tmp"
  else
    jq --arg v "$2" "$1 = \$v" "$STATE" > "$tmp"
  fi
  mv "$tmp" "$STATE"
}

# taghir tanzimat srasri: ratholectl set <key> <value>
cmd_set(){
  need_root; need_bin jq; ensure_state
  local key="${1:-}" val="${2:-}"
  [ -n "$key" ] && [ -n "$val" ] || die "estefade: ratholectl set <domain|fullchain|key|nginx-conf|fake-port|sub-port|control-port> <value>"
  case "$key" in
    domain)        state_set '.domain' "$val" str ;;
    fullchain)     state_set '.cert_fullchain' "$val" str ;;
    key)           state_set '.cert_key' "$val" str ;;
    nginx-conf)    state_set '.nginx_conf' "$val" str ;;
    fake-port)     state_set '.fake_port' "$val" num ;;
    sub-port)      state_set '.sub_port' "$val" num ;;
    control-port)  state_set '.control_port' "$val" num ;;
    *) die "kelid nashenakhte: $key" ;;
  esac
  log "tanzim shod: $key = $val"
  regenerate
}

# virayesh yek node: ratholectl edit <name> [--inbound N] [--api-port N|off]
cmd_edit(){
  need_root; need_bin jq; ensure_state
  local name="${1:-}"; shift || true
  [ -n "$name" ] || die "estefade: ratholectl edit <name> [--inbound N] [--api-port N|off]"
  jq -e --arg n "$name" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null || die "node '$name' peyda nashod."
  local inbound="" api="" tmp
  while [ $# -gt 0 ]; do case "$1" in
    --inbound)  inbound="$2"; shift 2;;
    --api-port) api="$2"; shift 2;;
    *) shift;;
  esac; done

  if [ -n "$inbound" ]; then
    echo "$inbound" | grep -qE '^[0-9]+$' || die "inbound bayad adad bashad."
    tmp="$(mktemp)"; jq --arg n "$name" --argjson ib "$inbound" \
      '(.nodes[] | select(.name==$n) | .inbound_port) |= $ib' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
    log "inbound node '$name' → $inbound"
  fi

  if [ -n "$api" ]; then
    if [ "$api" = off ]; then
      tmp="$(mktemp)"; jq --arg n "$name" \
        '(.nodes[] | select(.name==$n)) |= del(.api_local_port, .api_inbound_port, .api_token)' \
        "$STATE" > "$tmp" && mv "$tmp" "$STATE"
      log "channel mdirit node '$name' khamoosh shod."
    else
      echo "$api" | grep -qE '^[0-9]+$' || die "port api bayad adad bashad."
      local has_ap aport atoken astart
      has_ap="$(jq -r --arg n "$name" '.nodes[]|select(.name==$n)|.api_local_port // empty' "$STATE")"
      if [ -z "$has_ap" ]; then
        astart="$(s_get '.api_port_start')"; aport="$(next_port api_local_port "$astart")"; atoken="$(gen_token)"
        tmp="$(mktemp)"; jq --arg n "$name" --argjson ap "$aport" --argjson aib "$api" --arg at "$atoken" \
          '(.nodes[]|select(.name==$n)) |= (. + {api_local_port:$ap, api_inbound_port:$aib, api_token:$at})' \
          "$STATE" > "$tmp" && mv "$tmp" "$STATE"
        log "channel mdirit roshan shod (lvkal $aport)."
      else
        tmp="$(mktemp)"; jq --arg n "$name" --argjson aib "$api" \
          '(.nodes[]|select(.name==$n)|.api_inbound_port) |= $aib' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
        log "port inbound mdirit node '$name' → $api"
      fi
    fi
  fi
  regenerate
  print_node_install "$name"
}

# taghir name/masir node: ratholectl rename <old> <new>
cmd_rename(){
  need_root; need_bin jq; ensure_state
  local old="${1:-}" new="${2:-}"
  [ -n "$old" ] && [ -n "$new" ] || die "estefade: ratholectl rename <old> <new>"
  echo "$new" | grep -qE '^[a-zA-Z0-9_-]+$' || die "name jadid namotabar ast."
  is_reserved_name "$new" && die "name '$new' rezerv shode; name-e digari entekhab kon."
  jq -e --arg n "$old" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null || die "node '$old' peyda nashod."
  jq -e --arg n "$new" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null && die "name '$new' ghblaan vojood darad."
  local is_game; is_game="$(jq -r --arg n "$old" '.nodes[]|select(.name==$n)|.sni // empty' "$STATE")"
  local tmp; tmp="$(mktemp)"
  jq --arg o "$old" --arg n "$new" '(.nodes[]|select(.name==$o)|.name) |= $n' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  warn "masir karbar az /$old be /$new taghir krd; config karbaran va path inbound Xray node ra ham beroozresani kon."
  # MOHEM: rathole service ra ba NAME juft mikonad. node hanooz service-e '$old' ra darad,
  # pas tunnel ta zamani ke rooye node service ra rename nakoni ghat mimanad.
  warn "rooye node service ra ham rename kon (token sabet mimanad): 'ratholenode rm-svc $old' sps 'ratholenode add-svc $new <token> <inbound>' (ya baraye upstream, moadel-e upstream)."
  regenerate
  # dstvr-e nasb-e dorost bar asas-e no-e node (game=TLS/Vision , adi=WS)
  if [ -n "$is_game" ]; then print_game_install "$new"; else print_node_install "$new"; fi
}

# chrkhsh tokenha: ratholectl rotate <name>
cmd_rotate(){
  need_root; need_bin jq; ensure_state
  local name="${1:-}"
  [ -n "$name" ] || die "estefade: ratholectl rotate <name>"
  jq -e --arg n "$name" '.nodes[]|select(.name==$n)' "$STATE" >/dev/null || die "node '$name' peyda nashod."
  local tmp newt; tmp="$(mktemp)"; newt="$(gen_token)"
  jq --arg n "$name" --arg t "$newt" '(.nodes[]|select(.name==$n)|.token) |= $t' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  # agar channel mdirit dard, token an ham chrkhandh shavad
  if jq -e --arg n "$name" '.nodes[]|select(.name==$n)|.api_token' "$STATE" >/dev/null; then
    tmp="$(mktemp)"; jq --arg n "$name" --arg t "$(gen_token)" \
      '(.nodes[]|select(.name==$n)|.api_token) |= $t' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
  fi
  log "token node '$name' chrkhandh shod. rooye node bayad ba token jadid dvbarh nasb/beroozresani shavad."
  regenerate
  print_node_install "$name"
}

