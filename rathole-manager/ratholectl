# ---------- plain: tunnel-e websocket bedoon-e TLS (listener-e HTTP-e sade rooye port jda) ----------
# yek server-block-e HTTP (bedoon ssl) rooye port entekhabi baz mikonad ke websocket ra be
# port kontroli rathole forward mikonad. TLS-i dar in masir nist (sabok-tar, vali bedoon ramz-e nginx).
cmd_plain(){
  need_root; need_bin jq; ensure_state
  local sub="${1:-status}" port="${2:-}"
  case "$sub" in
    on)
      port="${port:-8880}"
      echo "$port" | grep -qE '^[0-9]+$' || die "port bayad adad bashad."
      [ "$port" = "443" ] && die "port 443 baraye halat TLS rezerv ast; port-e digari (masalan 8880) bede."
      state_set '.plain_port' "$port" num
      log "halat plain (bedoon TLS) faal shod: listener HTTP rooye port $port → kontrol rathole."
      warn "firewall: port TCP $port ra baz kon (masalan: ufw allow $port/tcp)."
      command -v ufw >/dev/null 2>&1 && ufw allow "$port/tcp" >/dev/null 2>&1 || true
      regenerate
      print_plain_connect
      ;;
    off)
      local tmp; tmp="$(mktemp)"; jq 'del(.plain_port)' "$STATE" > "$tmp" && mv "$tmp" "$STATE"
      log "halat plain khamoosh shod (listener HTTP hazf shod). node-ha bayad be halat TLS bargardand."
      regenerate
      ;;
    status)
      local pp; pp="$(jq -r '.plain_port // empty' "$STATE" 2>/dev/null)"
      if [ -n "$pp" ] && [ "$pp" != null ]; then
        echo "plain (bedoon TLS): $(c_g 'roshan')  listener HTTP rooye port $pp"
        command -v ss >/dev/null 2>&1 && { ss -ltnH "sport = :$pp" 2>/dev/null | grep -q . && echo "  gvshdadn TCP:$pp: $(c_g 'blh')" || echo "  gvshdadn TCP:$pp: $(c_r 'khir')"; }
      else
        echo "plain (bedoon TLS): $(c_y 'khamoosh')  (tunnelha rooye websocket/443 ba TLS)"
      fi
      ;;
    show) print_plain_connect ;;
    *) die "estefade: ratholectl plain <on [port]|off|status|show>" ;;
  esac
}

print_plain_connect(){
  local pp; pp="$(jq -r '.plain_port // empty' "$STATE" 2>/dev/null)"
  [ -n "$pp" ] && [ "$pp" != null ] || { warn "plain khamoosh ast; aval: ratholectl plain on [port]"; return; }
  local ip
