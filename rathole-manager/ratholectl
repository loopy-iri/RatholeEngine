# ---------- tune: BBR + limithaye system va nginx (rfa 502 zir burst) ----------
cmd_tune(){
  need_root
  log "eemal tuning system (BBR + file limits + conntrack + backlog)..."
  modprobe nf_conntrack 2>/dev/null || true
  cat >/etc/sysctl.d/99-rathole-tune.conf <<'EOF'
# BBR va sf khorooji
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_fastopen=3
# zrfit kankshn/file (rfa 502 zir burst WS/gim)
fs.file-max=2097152
net.core.somaxconn=65535
net.core.netdev_max_backlog=16384
net.ipv4.tcp_max_syn_backlog=65535
net.ipv4.ip_local_port_range=1024 65535
net.netfilter.nf_conntrack_max=1048576
# bafrhai bzrg UDP baraye kcptun (throughput bhtr rooye masir FEC)
net.core.rmem_max=26214400
net.core.wmem_max=26214400
net.core.rmem_default=26214400
net.core.wmem_default=26214400
EOF
  sysctl --system >/dev/null 2>&1 || true
  log "BBR=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)  conntrack_max=$(sysctl -n net.netfilter.nf_conntrack_max 2>/dev/null || echo n/a)"

  # tanzim worker nginx
  local nc=/etc/nginx/nginx.conf
  if [ -f "$nc" ]; then
    cp -a "$nc" "$nc.rathole-tune.bak"
    grep -q 'worker_rlimit_nofile' "$nc" || \
      sed -i '0,/^worker_processes/s//worker_rlimit_nofile 1048576;\nworker_processes/' "$nc"
    sed -i -E 's/worker_connections[[:space:]]+[0-9]+;/worker_connections 65535;/' "$nc"
    if nginx -t 2>/dev/null; then
      systemctl reload nginx
      log "nginx worker tuning eemal va reload shod."
    else
      err "nginx -t khata dad; backup bazgrdandh shod ($nc.rathole-tune.bak)."
      cp -a "$nc.rathole-tune.bak" "$nc"
    fi
  fi
  log "tuning kamel shod. rooye node kharej ham 'ratholenode tune' ra bezan."
}

