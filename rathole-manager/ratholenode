#!/usr/bin/env bash
# ratholenode — mdirit klaint rathole rooye node kharej (chnd service rooye yek tunnel)
# tanzimat paih: /etc/rathole/node.env   (SERVER, RATHOLE_VERSION)
# list serviceha: /etc/rathole/services.conf  (har kht: name|token|inbound_port)
# hame-ye serviceha zir yek [client] gharar migirand → yek channel kontroli (yek tunnel).
# nokte: amdan az `set -e` estefade nmiknim (dalil moshabeh ratholectl).
set -uo pipefail

# common.sh agar knar file bashd, tavabe eshteraki ra lvd kon
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd || echo "$PWD")"
[ -f "$SCRIPT_DIR/common.sh" ] && source "$SCRIPT_DIR/common.sh"

# pak-sazi temp files dar khrvj; har masir yek ansre arraye ta msire darai faasele ham dorost pak shavad.
_RTH_TMP=()
_rth_cleanup(){ [ "${#_RTH_TMP[@]}" -gt 0 ] && rm -rf -- "${_RTH_TMP[@]}"; }
trap _rth_cleanup EXIT INT TERM
rth_mktemp(){ local p; p="$(mktemp "$@")" || return 1; _RTH_TMP+=("$p"); echo "$p"; }
rth_mktempd(){ local d; d="$(mktemp -d "$@")" || return 1; _RTH_TMP+=("$d"); echo "$d"; }

ENV_FILE="/etc/rathole/node.env"
SVC_FILE="/etc/rathole/services.conf"
CLIENT_TOML="/etc/rathole/client.toml"
SVC="rathole-client"

c_g(){ printf '\033[1;32m%s\033[0m' "$*"; }
c_r(){ printf '\033[1;31m%s\033[0m' "$*"; }
c_y(){ printf '\033[1;33m%s\033[0m' "$*"; }
log(){ printf '%s %s\n' "$(c_g '[+]')" "$*"; }
warn(){ printf '%s %s\n' "$(c_y '[*]')" "$*"; }
err(){ printf '%s %s\n' "$(c_r '[!]')" "$*" >&2; }
die(){ err "$*"; exit 1; }
need_root(){ [ "$(id -u)" -eq 0 ] || die "bayad ba root ejra shavad."; }

load_env(){ [ -f "$ENV_FILE" ] || die "node.env peyda nshd; aval install-node.sh ra ejra kon."; set -a; . "$ENV_FILE"; set +a; }

# barresi tadakhol port inbound ba nginx node + sair servicehaye tunnel
check_inbound(){
  local port="$1" label="$2" owner
  if [ "$port" = "80" ] || [ "$port" = "443" ]; then
    warn "$label rooye port $port ast ke maamoolan motaaleq be nginx node ast — ehtemal tadakhol."
  fi
  if command -v ss >/dev/null 2>&1; then
    owner="$(ss -ltnpH "sport = :$port" 2>/dev/null | grep -oE 'users:\(\("[^"]+' | sed 's/.*"//' | head -1)"
    if [ -n "$owner" ] && echo "$owner" | grep -qiE 'nginx'; then
      err "$label (port $port) motaaleq be nginx ast. port digari entekhab kon."
      return 1
    fi
  fi
  return 0
}

# barresi tadakhol port inbound
# nokte-ye mohem: dar samt-e node, `local_addr` yek MAGHSAD ast (rathole traffic ra be an
# tahvil midahad), na yek port-e listen. bnbrin yek inbound-e vahed (masalan 127.0.0.1:2087)
# mitavanad hamzaman az chand server-e Iran (main + chand upstream) traffic begirad (fan-in).
# pas eshterak-e port bein-e tunnelha MOJAZ ast va nabayad block shavad.
# tanha tadakhol-e vaghei ba nginx-e node (80/443) ast ke check_inbound an ra migirad.
# argument sevom (self) faghat baraye sazgari-ye emza negah dashte shode.
check_port_conflict(){
  local port="$1" label="$2" self="${3:-}"
  check_inbound "$port" "$label" || return 1
  return 0
}



# tvlid client.toml az node.env + services.conf (hame zir yek [client])
gen_client(){
  load_env
  [ -f "$SVC_FILE" ] || die "hich srvisi tarif nashode ($SVC_FILE). ba 'ratholenode add-svc' ezafe kon."
  local host="${SERVER%%:*}"
  local mode="${TUNNEL:-ws}" remote tls hostline
  if [ "$mode" = "kcp" ]; then
    # masir az trigh kcptun lvkal mirvd; TLS lazem nist (kcp khodesh ramz/FEC darad)
    remote="${KCP_LOCAL:-127.0.0.1:29900}"
    tls="false"; hostline=""
  elif [ "$mode" = "plain" ]; then
    # tunnel-e websocket bedoon-e TLS: mostaghim be port-e HTTP-e sade rooye server Iran
    remote="${PLAIN_REMOTE:-$SERVER}"; tls="false"; hostline=""
  elif [ "$mode" = "noise" ]; then
    # tunnel-e ramznegari-shode ba Noise: mostaghim be port-e omomi-ye rathole-noise rooye Iran (bedoon TLS/cert)
    remote="${NOISE_REMOTE:-$SERVER}"; tls="false"; hostline=""
  else
    remote="${SERVER}"; tls="true"; hostline="hostname = \"${host}\""
  fi

  {
    echo "# tvlid khodkar tvst ratholenode — dasti virayesh nakon (tunnel=${mode})"
    local hbt="${HEARTBEAT_TIMEOUT:-40}"; [ "$mode" = "kcp" ] && hbt="${KCP_HEARTBEAT_TIMEOUT:-90}"
    echo "[client]"
    echo "remote_addr = \"${remote}\""
    echo "retry_interval = 1"
    echo "heartbeat_timeout = ${hbt}"
    echo
    echo "[client.transport]"
    if [ "$mode" = "noise" ]; then
      echo "type = \"noise\""
      echo "[client.transport.noise]"
      echo "pattern = \"${NOISE_PATTERN:-Noise_NK_25519_ChaChaPoly_BLAKE2s}\""
      echo "remote_public_key = \"${NOISE_PUBKEY}\""
    else
      echo "type = \"websocket\""
      echo "[client.transport.websocket]"
      echo "tls = ${tls}"
      if [ "$tls" = "true" ]; then
        echo "[client.transport.tls]"
        echo "$hostline"
      fi
    fi
    while IFS='|' read -r name token inbound; do
      [ -n "$name" ] || continue
      case "$name" in \#*) continue ;; esac
      # CR-e entehai ra pak kon (agar services.conf ba CRLF zakhire shode bashad) va
      # khatt-e naghes (token/inbound-e khali) ra rad kon — vagarna TOML-e namotabar tolid
      # mishavad va rathole KOLL-e config ra rad mikonad (hame-ye service-ha down).
      token="${token%$'\r'}"; inbound="${inbound%$'\r'}"
      if [ -z "$token" ] || ! echo "$inbound" | grep -qE '^[0-9]+$'; then
        warn "khatt-e namotabar dar services.conf rad shod (name=$name)."
        continue
      fi
      echo
      echo "[client.services.${name}]"
      echo "token = \"${token}\""
      echo "local_addr = \"127.0.0.1:${inbound}\""
      echo "type = \"tcp\""
    done < "$SVC_FILE"
  } > "$CLIENT_TOML.tmp"
  # neveshtan in-place (hefz inode) ta rathole ba config_watcher hot-reload konad (bedoon ghati servicehaye faal mesl game)
  cat "$CLIENT_TOML.tmp" > "$CLIENT_TOML" && rm -f "$CLIENT_TOML.tmp"
}

# restart kamel (fght baraye taghir trnspvrt mesl kcp on/off lazem ast)
restart_svc(){
  systemctl daemon-reload 2>/dev/null || true
  systemctl enable "$SVC" >/dev/null 2>&1 || true
  systemctl restart "$SVC" 2>/dev/null && log "$SVC restart shod." || warn "restart $SVC nashod."
}

# hot-reload: fght agar service khamoosh bood start miknd; dar ghir ainsvrt rathole khodesh config ra mikhanad (bedoon ghati)
reload_svc(){
  systemctl daemon-reload 2>/dev/null || true
  systemctl enable "$SVC" >/dev/null 2>&1 || true
  if systemctl is-active --quiet "$SVC"; then
    log "client.toml berooz shd; rathole hot-reload mikonad (tunnelhaye faal mesl game ghat nmishvnd)."
  else
    systemctl start "$SVC" 2>/dev/null && log "$SVC start shod." || warn "start $SVC nashod."
  fi
}

cmd_apply(){
  need_root; load_env
  # check tadakhol port baraye har service
  if [ -f "$SVC_FILE" ]; then
    while IFS='|' read -r name token inbound; do
      [ -n "$name" ] || continue; case "$name" in \#*) continue ;; esac
      check_port_conflict "$inbound" "inbound $name" "$name" || warn "ba vojood tadakhol adamh midhim."
    done < "$SVC_FILE"

  fi
  gen_client
  reload_svc
  log "client.toml ba $(grep -cvE '^\s*(#|$)' "$SVC_FILE" 2>/dev/null || echo 0) service rooye yek tunnel sakhte shod."
}

svc_exists(){ grep -qE "^$1\|" "$SVC_FILE" 2>/dev/null; }

# aatbarsnji-ye moshtarak baraye name/token-e service (jelogiri az tzrigh be TOML/services.conf)
valid_svc_name(){ echo "$1" | grep -qE '^[a-zA-Z0-9_-]+$'; }
# token bayad az '|' (jodakonande-ye services.conf) va newline/space va metachar-e TOML khali bashad.
valid_svc_token(){ echo "$1" | grep -qE '^[A-Za-z0-9._=+/-]+$'; }

cmd_add_svc(){
  need_root
  local name="${1:-}" token="${2:-}" inbound="${3:-}"
  [ -n "$name" ] && [ -n "$token" ] && [ -n "$inbound" ] || die "estefade: ratholenode add-svc <name> <token> <inbound_port>"
  valid_svc_name "$name" || die "name namotabar."
  valid_svc_token "$token" || die "token namotabar (faghat [A-Za-z0-9._=+/-] mjaz ast)."
  echo "$inbound" | grep -qE '^[0-9]+$' || die "port bayad adad bashad."
  check_port_conflict "$inbound" "service '$name'" || die "tadakhol port — meghdar digari entekhab kon."
  touch "$SVC_FILE"; chmod 600 "$SVC_FILE"
  if svc_exists "$name"; then
    warn "service '$name' vojood dard; beroozresani mishavad."
    sed -i "/^$name|/d" "$SVC_FILE"
  fi
  echo "${name}|${token}|${inbound}" >> "$SVC_FILE"
  log "service '$name' → 127.0.0.1:$inbound ezafe shod (haman tunnel)."
  cmd_apply
}

cmd_rm_svc(){
  need_root
  local name="${1:-}"
  [ -n "$name" ] || die "estefade: ratholenode rm-svc <name>"
  valid_svc_name "$name" || die "name namotabar."
  svc_exists "$name" || die "service '$name' peyda nashod."
  sed -i "/^$name|/d" "$SVC_FILE"
  log "service '$name' hazf shod."
  cmd_apply
}

cmd_ls(){
  [ -f "$SVC_FILE" ] || { warn "hich srvisi nist."; return; }
  load_env
  echo "tunnel be: $(c_y "${SERVER:-?}")  (hame serviceha rooye yek channel kontroli)"
  printf '%-16s %-10s %s\n' "SERVICE" "INBOUND" "TOKEN"
  printf '%s\n' "-------------------------------------------"
  while IFS='|' read -r name token inbound; do
    [ -n "$name" ] || continue; case "$name" in \#*) continue ;; esac
    printf '%-16s %-10s %s\n' "$name" "$inbound" "${token:0:8}…"
  done < "$SVC_FILE"
}

cmd_set(){
  need_root; load_env
  local key="${1:-}" val="${2:-}"
  [ -n "$key" ] && [ -n "$val" ] || die "estefade: ratholenode set <SERVER|RATHOLE_VERSION> <value>"
  case "$key" in SERVER|RATHOLE_VERSION) ;; *) die "kelid nashenakhte: $key (baraye serviceha az add-svc/rm-svc estefade kon)";; esac
  # val ra etebar-sanji kon: hich metachar-e sed (# & \ / newline) nabayad dashte bashad,
  # vagarna sed-e paiin ('s#...#...#') mishkanad ya jایgozini-ye eshtebah mikonad.
  case "$key" in
    SERVER)          echo "$val" | grep -qE '^[A-Za-z0-9_.-]+(:[0-9]{1,5})?$' || die "SERVER namotabar (host ya host:port)." ;;
    RATHOLE_VERSION) echo "$val" | grep -qE '^[A-Za-z0-9_.-]+$' || die "RATHOLE_VERSION namotabar." ;;
  esac
  if grep -qE "^${key}=" "$ENV_FILE"; then sed -i "s#^${key}=.*#${key}=${val}#" "$ENV_FILE"; else echo "${key}=${val}" >> "$ENV_FILE"; fi
  log "tanzim shod: $key = $val"
  cmd_apply
}

cmd_show(){
  load_env
  echo "$(c_g '== node.env ==')"; cat "$ENV_FILE"
  echo; echo "$(c_g '== services ==')"; cmd_ls
}
cmd_status(){ systemctl --no-pager status "$SVC" | sed -n '1,12p' || true; }
cmd_logs(){ journalctl -u "$SVC" -n "${1:-50}" --no-pager || true; }

# ---------- kcp/FEC tunnel samt node (switch masir tunnel az 443 be UDP+FEC) ----------
KCP_CLI_BIN=/usr/local/bin/kcptun-client
KCP_CLI_UNIT=/etc/systemd/system/rathole-kcp-client.service
KCPTUN_VER_DEF="v20260129"
KCPTUN_BASE_DEF="https://github.com/ossfork/kcptun/releases/download"
KCP_LOCAL_DEF="127.0.0.1:29900"

env_set(){ # $1=key $2=value (dar node.env)
  touch "$ENV_FILE"
  if grep -qE "^$1=" "$ENV_FILE"; then sed -i "s#^$1=.*#$1=$2#" "$ENV_FILE"; else echo "$1=$2" >> "$ENV_FILE"; fi
}

install_kcptun_client(){
  local bin="$KCP_CLI_BIN" ver="${KCPTUN_VER:-$KCPTUN_VER_DEF}" base="${KCPTUN_BASE:-$KCPTUN_BASE_DEF}" arch tmp url
  [ -x "$bin" ] && return 0
  case "$(uname -m)" in x86_64) arch=amd64 ;; aarch64) arch=arm64 ;; armv7l) arch=armv7 ;; *) die "memari poshtibani nemishavad." ;; esac
  command -v curl >/dev/null 2>&1 || die "curl lazem ast."
  log "download kcptun ${ver}..."
  tmp="$(rth_mktempd)"
  url="${base}/${ver}/kcptun_linux_${arch}.tar.gz"
  curl -fsSL "$url" -o "$tmp/k.tgz" || { rm -rf "$tmp"; die "download kcptun shekast khord."; }
  tar -xzf "$tmp/k.tgz" -C "$tmp" || { rm -rf "$tmp"; die "baz kardan arshiv shekast khord."; }
  install -m755 "$tmp/client_linux_${arch}" "$bin" || { rm -rf "$tmp"; die "nasb bainri shekast khord."; }
  rm -rf "$tmp"; log "kcptun-client nasb shod."
}

gen_kcp_client_unit(){ # $1=remote $2=local $3=key $4=ds $5=ps $6=mode $7=sw $8=rw
  local remote="$1" local_ep="$2" key="$3" ds="$4" ps="$5" mode="$6" sw="$7" rw="$8"
  cat > "$KCP_CLI_UNIT" <<UNIT
[Unit]
Description=rathole kcp-client (local TCP -> UDP+FEC to Iran)
After=network.target

[Service]
Type=simple
ExecStart=${KCP_CLI_BIN} -r ${remote} -l ${local_ep} -key ${key} -crypt aes-128 -mode ${mode} -mtu 1350 -sndwnd ${sw} -rcvwnd ${rw} -datashard ${ds} -parityshard ${ps} -dscp 46 -nocomp
Restart=always
RestartSec=2
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
UNIT
}

# profile FEC → "datashard parityshard mode sndwnd rcvwnd" (bayad ba server Iran iki bashad)
kcp_profile(){
  case "${1:-balanced}" in
    balanced)   echo "10 3 fast2 2048 2048" ;;
    lossy)      echo "10 5 fast2 2048 2048" ;;
    aggressive) echo "10 4 fast3 4096 4096" ;;
    *) return 1 ;;
  esac
}

cmd_kcp(){
  need_root
  local sub="${1:-status}"; shift || true
  case "$sub" in
    on)   cmd_kcp_on "$@" ;;
    off)  cmd_kcp_off ;;
    status) cmd_kcp_status ;;
    *) die "estefade: ratholenode kcp <on <iran_ip:udp_port> <key> [profile]|off|status>" ;;
  esac
}

cmd_kcp_on(){
  local remote="${1:-}" key="${2:-}" profile="${3:-balanced}" local_ep="${KCP_LOCAL:-$KCP_LOCAL_DEF}" params ds ps mode sw rw
  [ -n "$remote" ] && [ -n "$key" ] || die "estefade: ratholenode kcp on <iran_ip:udp_port> <key> [profile]"
  echo "$remote" | grep -qE '^[^:]+:[0-9]+$' || die "adres bayad be shkl IP:PORT bashad."
  params="$(kcp_profile "$profile")" || die "profile namotabar: $profile (balanced|lossy|aggressive)"
  read -r ds ps mode sw rw <<<"$params"
  install_kcptun_client
  gen_kcp_client_unit "$remote" "$local_ep" "$key" "$ds" "$ps" "$mode" "$sw" "$rw"
  systemctl daemon-reload
  systemctl enable rathole-kcp-client >/dev/null 2>&1
  systemctl restart rathole-kcp-client 2>/dev/null
  if systemctl is-active --quiet rathole-kcp-client; then
    log "kcp-client faal shod: $local_ep → UDP $remote (profile: $profile)."
  else
    err "rathole-kcp-client bala niamd; log: journalctl -u rathole-kcp-client -n 30"
    return 1
  fi
  # switch tunnel be kcp va baztolid client.toml
  env_set TUNNEL kcp
  env_set KCP_LOCAL "$local_ep"
  env_set KCP_REMOTE "$remote"
  env_set KCP_PROFILE "$profile"
  gen_client
  restart_svc
  log "tunnel be masir kcp/UDP+FEC switch shod. serviceha/tokenha/path karbaran taghir nakard."
  warn "agar serviceha vsl nshdnd, rooye Iran motmaen shv 'ratholectl kcp on' ba haman profile zade shode va UDP baz ast."
}

cmd_kcp_off(){
  systemctl disable --now rathole-kcp-client 2>/dev/null || true
  rm -f "$KCP_CLI_UNIT"; systemctl daemon-reload 2>/dev/null || true
  env_set TUNNEL ws
  gen_client
  restart_svc
  log "tunnel be halat websocket/443 bargasht."
}

cmd_kcp_status(){
  load_env
  local mode="${TUNNEL:-ws}"
  echo "halat tunnel: $(c_y "$mode")"
  if [ "$mode" = "kcp" ]; then
    echo "  local: ${KCP_LOCAL:-?}   remote(UDP): ${KCP_REMOTE:-?}   profile: ${KCP_PROFILE:-balanced}"
    case "${KCP_REMOTE:-}" in *:443) echo "  estetar: UDP/443 ~ QUIC/HTTP3" ;; esac
    systemctl is-active --quiet rathole-kcp-client && echo "  kcp-client: $(c_g 'active')" || echo "  kcp-client: $(c_r 'inactive')"
  fi
  systemctl is-active --quiet "$SVC" && echo "  $SVC: $(c_g 'active')" || echo "  $SVC: $(c_r 'inactive')"
}

# ---------- plain: tunnel-e websocket bedoon-e TLS (mostaghim be port HTTP-e sade rooye Iran) ----------
cmd_plain(){
  need_root
  local sub="${1:-status}"; shift || true
  case "$sub" in
    on)   cmd_plain_on "$@" ;;
    off)  cmd_plain_off ;;
    status) cmd_plain_status ;;
    *) die "estefade: ratholenode plain <on <iran_ip:port>|off|status>" ;;
  esac
}

cmd_plain_on(){
  local remote="${1:-}"
  [ -n "$remote" ] || die "estefade: ratholenode plain on <iran_ip:port>  (port-e HTTP-e sade rooye Iran, masalan 8880)"
  echo "$remote" | grep -qE '^[^:]+:[0-9]+$' || die "adres bayad be shkl IP:PORT bashad (masalan 1.2.3.4:8880)."
  env_set TUNNEL plain
  env_set PLAIN_REMOTE "$remote"
  gen_client
  restart_svc
  log "tunnel be halat plain (bedoon TLS) switch shod → ws://$remote"
  warn "rooye server Iran motmaen shv 'ratholectl plain on [port]' zade shode va port TCP baz ast."
}

cmd_plain_off(){
  env_set TUNNEL ws
  gen_client
  restart_svc
  log "tunnel be halat websocket/443 (ba TLS) bargasht."
}

cmd_plain_status(){
  load_env
  local mode="${TUNNEL:-ws}"
  echo "halat tunnel: $(c_y "$mode")"
  [ "$mode" = "plain" ] && echo "  remote(ws bedoon TLS): ${PLAIN_REMOTE:-?}"
  systemctl is-active --quiet "$SVC" && echo "  $SVC: $(c_g 'active')" || echo "  $SVC: $(c_r 'inactive')"
}

# ---------- noise: tunnel-e ramznegari-shode (rathole Noise) mostaghim be port-e omomi-ye rathole-noise rooye Iran ----------
# bedoon TLS/cert; ramznegari tavassot-e khod-e Noise (X25519+ChaChaPoly). faghat kelid-e omomi-ye server niaz ast.
cmd_noise(){
  need_root
  local sub="${1:-status}"; shift || true
  case "$sub" in
    on)   cmd_noise_on "$@" ;;
    off)  cmd_noise_off ;;
    status) cmd_noise_status ;;
    *) die "estefade: ratholenode noise <on <iran_ip:port> <pubkey> [pattern]|off|status>" ;;
  esac
}

cmd_noise_on(){
  local remote="${1:-}" pubkey="${2:-}" pattern="${3:-}"
  [ -n "$remote" ] && [ -n "$pubkey" ] || die "estefade: ratholenode noise on <iran_ip:port> <pubkey> [pattern]  (port-e omomi-ye rathole-noise rooye Iran, masalan 2334)"
  echo "$remote" | grep -qE '^[^:]+:[0-9]+$' || die "adres bayad be shkl IP:PORT bashad (masalan 1.2.3.4:2334)."
  echo "$pubkey" | grep -qE '^[A-Za-z0-9+/]{40,64}={0,2}$' || die "pubkey bayad base64-e motabar bashad (az 'ratholectl noise show' rooye Iran)."
  env_set TUNNEL noise
  env_set NOISE_REMOTE "$remote"
  env_set NOISE_PUBKEY "$pubkey"
  [ -n "$pattern" ] && env_set NOISE_PATTERN "$pattern" || env_set NOISE_PATTERN "Noise_NK_25519_ChaChaPoly_BLAKE2s"
  gen_client
  restart_svc
  log "tunnel be halat noise (ramznegari-shode) switch shod → noise://$remote"
  warn "rooye server Iran motmaen shv 'ratholectl noise on' zade shode va in node ba 'ratholectl noise node <name> on' faal shode va port TCP baz ast."
}

cmd_noise_off(){
  env_set TUNNEL ws
  gen_client
  restart_svc
  log "tunnel be halat websocket/443 (ba TLS) bargasht."
}

cmd_noise_status(){
  load_env
  local mode="${TUNNEL:-ws}"
  echo "halat tunnel: $(c_y "$mode")"
  if [ "$mode" = "noise" ]; then
    echo "  remote(noise, ramznegari-shode): ${NOISE_REMOTE:-?}"
    echo "  pubkey-e server: ${NOISE_PUBKEY:-?}"
  fi
  systemctl is-active --quiet "$SVC" && echo "  $SVC: $(c_g 'active')" || echo "  $SVC: $(c_r 'inactive')"
}

cmd_tune(){

  need_root
  modprobe nf_conntrack 2>/dev/null || true
  cat >/etc/sysctl.d/99-rathole-tune.conf <<'EOF'
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_fastopen=3
fs.file-max=2097152
net.core.somaxconn=65535
net.core.netdev_max_backlog=16384
net.ipv4.tcp_max_syn_backlog=65535
net.ipv4.ip_local_port_range=1024 65535
net.netfilter.nf_conntrack_max=1048576
net.core.rmem_max=26214400
net.core.wmem_max=26214400
net.core.rmem_default=26214400
net.core.wmem_default=26214400
EOF
  sysctl --system >/dev/null 2>&1 || true
  log "tuning node eemal shod. BBR=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)"
}

# web fik sabok baraye fallback inbound TLS/Reality
FAKEWEB_SVC="rathole-fakeweb"
cmd_fakeweb(){
  need_root
  local action="${1:-}" port="${2:-8081}"
  case "$action" in
    start)
      command -v python3 >/dev/null 2>&1 || die "python3 nasb nist (apt install -y python3)."
      mkdir -p /var/www/rathole-fake
      [ -f /var/www/rathole-fake/index.html ] || cat > /var/www/rathole-fake/index.html <<'HTML'
<!doctype html><html><head><meta charset="utf-8"><title>Welcome</title></head>
<body style="font-family:sans-serif"><h1>It works!</h1><p>Default web page.</p></body></html>
HTML
      cat > /etc/systemd/system/${FAKEWEB_SVC}.service <<UNIT
[Unit]
Description=rathole fake web (TLS fallback)
After=network.target

[Service]
ExecStart=/usr/bin/python3 -m http.server ${port} --bind 127.0.0.1 --directory /var/www/rathole-fake
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
UNIT
      systemctl daemon-reload
      systemctl enable --now ${FAKEWEB_SVC}
      log "web fik rooye 127.0.0.1:${port} bala amad (baraye fallback inbound)."
      ;;
    stop)
      systemctl stop ${FAKEWEB_SVC} 2>/dev/null && log "web fik motevaghef shod." || warn "web fik ejra naboodan."
      ;;
